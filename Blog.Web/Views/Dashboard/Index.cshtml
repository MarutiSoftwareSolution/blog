@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-6">
    @* ── Onboarding Checklist (first-time user) ────────────────── *@
    @if (ViewBag.ShowOnboarding == true)
    {
        @await Html.PartialAsync("_OnboardingChecklist", (HashSet<string>)ViewBag.OnboardingCompleted)
    }

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Posts -->
        <div class="p-6 bg-card text-card-foreground rounded-lg shadow-sm border border-border flex items-center gap-4">
            <div class="p-3 bg-primary/10 text-primary rounded-full">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">Total Posts</p>
                <h3 class="text-2xl font-bold">@ViewBag.TotalPosts</h3>
            </div>
        </div>

        <!-- Published -->
        <div class="p-6 bg-card text-card-foreground rounded-lg shadow-sm border border-border flex items-center gap-4">
            <div class="p-3 bg-green-100 text-green-700 rounded-full">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">Published</p>
                <h3 class="text-2xl font-bold">@ViewBag.PublishedPosts</h3>
            </div>
        </div>

        <!-- Drafts -->
        <div class="p-6 bg-card text-card-foreground rounded-lg shadow-sm border border-border flex items-center gap-4">
            <div class="p-3 bg-yellow-100 text-yellow-700 rounded-full">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">Drafts</p>
                <h3 class="text-2xl font-bold">@ViewBag.DraftPosts</h3>
            </div>
        </div>

        <!-- Pending Comments -->
        <div class="p-6 bg-card text-card-foreground rounded-lg shadow-sm border border-border flex items-center gap-4 relative overflow-hidden">
             @if (ViewBag.PendingComments > 0)
            {
                <div class="absolute top-0 right-0 w-3 h-3 bg-destructive rounded-full mr-2 mt-2 animate-ping"></div>
                <div class="absolute top-0 right-0 w-3 h-3 bg-destructive rounded-full mr-2 mt-2"></div>
            }
            <div class="p-3 bg-blue-100 text-blue-700 rounded-full">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">Pending Comments</p>
                <h3 class="text-2xl font-bold">@ViewBag.PendingComments</h3>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-card rounded-lg shadow-sm border border-border p-6">
        <h2 class="text-lg font-semibold mb-4">Quick Actions</h2>
        <div class="flex flex-wrap gap-4">
            <a href="/admin/posts/create" class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors font-medium text-sm shadow-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Post
            </a>
            <a href="/admin/media" class="inline-flex items-center gap-2 px-4 py-2 bg-secondary text-secondary-foreground rounded-md hover:bg-secondary/80 transition-colors font-medium text-sm border border-border shadow-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                Upload Media
            </a>
            <a href="/admin/comments" class="inline-flex items-center gap-2 px-4 py-2 bg-secondary text-secondary-foreground rounded-md hover:bg-secondary/80 transition-colors font-medium text-sm border border-border shadow-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Moderate Comments
            </a>
        </div>
    </div>

    <!-- Recent Posts -->
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        <div class="p-6 border-b border-border flex items-center justify-between">
            <h2 class="text-lg font-semibold">Recent Posts</h2>
            <a href="/admin/posts" class="text-sm font-medium text-primary hover:text-primary/80 flex items-center gap-1">
                View all <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
        </div>
        
        @if (ViewBag.RecentPosts != null && ((List<Blog.Core.Domain.Post>)ViewBag.RecentPosts).Any())
        {
            <div class="divide-y divide-border">
                @foreach (var post in (List<Blog.Core.Domain.Post>)ViewBag.RecentPosts)
                {
                    <div class="p-4 flex flex-col md:flex-row md:items-center justify-between gap-4 hover:bg-muted/50 transition-colors">
                        <div class="space-y-1">
                            <a href="/admin/posts/edit/@post.Id" class="font-medium text-foreground hover:text-primary transition-colors block">@post.Title</a>
                            <div class="flex items-center gap-3 text-xs text-muted-foreground">
                                @{
                                    var displayStatus = post.Status;
                                    if (post.Status == Blog.Core.Domain.PostStatus.Scheduled && post.ScheduledAt <= DateTime.Now)
                                    {
                                        displayStatus = Blog.Core.Domain.PostStatus.Published;
                                    }
                                }
                                <span class="capitalize px-2 py-0.5 rounded-full text-[10px] font-bold tracking-wide
                                    @(displayStatus == Blog.Core.Domain.PostStatus.Published ? "bg-green-100 text-green-700" : 
                                      displayStatus == Blog.Core.Domain.PostStatus.Draft ? "bg-yellow-100 text-yellow-700" : "bg-blue-100 text-blue-700")">
                                    @displayStatus
                                </span>
                                <span>@post.CreatedAt.ToString("MMM d, yyyy")</span>
                                <span>@post.ViewCount views</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                             @if (post.Status == Blog.Core.Domain.PostStatus.Published || (post.Status == Blog.Core.Domain.PostStatus.Scheduled && post.ScheduledAt <= DateTime.Now))
                            {
                                <a href="/@post.Slug" target="_blank" class="p-2 text-muted-foreground hover:text-foreground hover:bg-muted rounded transition-colors" title="View">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                </a>
                            }
                            <a href="/admin/posts/edit/@post.Id" class="px-3 py-1.5 text-sm font-medium text-foreground bg-white border border-input rounded hover:bg-accent hover:text-accent-foreground transition-colors shadow-sm">
                                Edit
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-12 text-center text-muted-foreground">
                <svg class="mx-auto h-12 w-12 text-muted-foreground/50 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                <p>No posts yet.</p>
                <a href="/admin/posts/create" class="mt-2 text-primary hover:underline font-medium inline-block">Write your first post →</a>
            </div>
        }
    </div>
</div>
