@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();

    var isFirstPage = Model.Page == 1 && !selectedCategories.Any() && !selectedTags.Any() && string.IsNullOrEmpty(searchTerm);

    string GetToggleUrl(string type, string slug)
    {
        var currentCats = new List<string>(selectedCategories);
        var currentTags = new List<string>(selectedTags);
        if (type == "category") { if (currentCats.Contains(slug)) currentCats.Remove(slug); else currentCats.Add(slug); }
        else if (type == "tags") { if (currentTags.Contains(slug)) currentTags.Remove(slug); else currentTags.Add(slug); }
        var q = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) q.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (currentCats.Any()) q.Add("category=" + string.Join(",", currentCats));
        if (currentTags.Any()) q.Add("tags=" + string.Join(",", currentTags));
        return q.Any() ? "?" + string.Join("&", q) : "/";
    }
}

@* ── GRID CONTENT ─────────────────────────────────────────────── *@
<div class="container xl:max-w-6xl mx-auto px-4 py-8">

    @* ── FILTER BOX ─────────────────────────────────────────────── *@
    @if ((ViewBag.Categories != null && ((IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories).Any()) || 
         (ViewBag.Tags != null && ((IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags).Any()))
    {
        <div class="mb-10 border rounded-xl overflow-hidden shadow-sm" style="background: var(--card); border-color: var(--border);">
            <div class="px-5 py-4 border-b flex justify-between items-center" style="border-color: var(--border); background: var(--muted);">
                <h3 class="font-bold uppercase tracking-wider text-xs flex items-center gap-2">
                    <i class="bi bi-funnel"></i> Filter Box
                </h3>
                @if (selectedCategories.Any() || selectedTags.Any()) {
                    <a href="/" class="text-[10px] font-bold uppercase underline hover:opacity-70 text-red-500">Clear All</a>
                }
            </div>
            
            <div class="p-5 flex flex-col md:flex-row gap-8">
                @if (ViewBag.Categories != null)
                {
                    var allCats = (IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories;
                    if (allCats.Any())
                    {
                        <div class="flex-1">
                            <h4 class="text-xs uppercase font-bold mb-3" style="color: var(--muted-foreground);">Categories</h4>
                            <div class="flex flex-wrap gap-2">
                                <a href="/" class="px-3 py-1 rounded text-xs font-semibold border transition-all"
                                   style="background: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--primary)" : "var(--muted)");
                                          color: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--primary-foreground)" : "var(--foreground)");
                                          border-color: var(--border);">All</a>
                                @foreach (var cat in allCats)
                                {
                                    bool isOn = selectedCategories.Contains(cat.Slug);
                                    <a href="@GetToggleUrl("category", cat.Slug)" class="px-3 py-1 rounded text-xs font-semibold border transition-all hover:opacity-80"
                                       style="background: @(isOn ? "var(--primary)" : "var(--background)");
                                              color: @(isOn ? "var(--primary-foreground)" : "var(--foreground)");
                                              border-color: @(isOn ? "var(--primary)" : "var(--border)");">
                                        @cat.Name
                                    </a>
                                }
                            </div>
                        </div>
                    }
                }
                
                @if (ViewBag.Tags != null)
                {
                    var allTags = (IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags;
                    if (allTags.Any())
                    {
                        <div class="flex-1">
                            <h4 class="text-xs uppercase font-bold mb-3" style="color: var(--muted-foreground);">Tags</h4>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var tag in allTags)
                                {
                                    bool isSelTag = selectedTags.Contains(tag.Slug);
                                    <a href="@GetToggleUrl("tags", tag.Slug)" class="px-2 py-1 rounded text-[10px] uppercase font-bold tracking-wider border transition-all hover:opacity-80"
                                       style="background: @(isSelTag ? "var(--foreground)" : "transparent");
                                              color: @(isSelTag ? "var(--background)" : "var(--muted-foreground)");
                                              border-color: var(--border);">
                                        #@tag.Name
                                    </a>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div class="mb-6 flex items-center gap-3">
            <span style="color: var(--muted-foreground);">Search:</span>
            <strong>"@searchTerm"</strong>
            <a href="/" class="text-xs px-3 py-1 rounded-full border" style="border-color: var(--border);">Clear ✕</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="py-24 flex flex-col items-center gap-4 text-center">
            <i class="bi bi-grid-3x3-gap text-6xl" style="color: var(--muted-foreground);"></i>
            <h3 class="text-2xl font-bold">No posts found</h3>
            <p style="color: var(--muted-foreground);">Try adjusting your filters.</p>
            <a href="/" class="mt-2 px-6 py-2.5 rounded-lg font-semibold text-sm"
               style="background: var(--primary); color: var(--primary-foreground);">Back to Home</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in Model.Items)
            {
                <partial name="_PostCard_Grid" model="post" />
            }
        </div>
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        var qParts = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
        if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
        var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";

        <div class="flex items-center justify-center gap-2 mt-12 pt-8 border-t" style="border-color: var(--border);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page - 1)@baseQuery"
                   class="w-10 h-10 rounded-xl border flex items-center justify-center hover:opacity-80"
                   style="background: var(--card); border-color: var(--border);">
                    <i class="bi bi-chevron-left"></i>
                </a>
            }
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == 1 || i == Model.TotalPages || (i >= Model.Page - 1 && i <= Model.Page + 1))
                {
                    <a href="?page=@i@baseQuery"
                       class="w-10 h-10 rounded-xl border flex items-center justify-center text-sm font-semibold hover:opacity-80 @(i == Model.Page ? "font-black shadow-md" : "")"
                       style="background: @(i == Model.Page ? "var(--primary)" : "var(--card)");
                              color: @(i == Model.Page ? "var(--primary-foreground)" : "var(--foreground)");
                              border-color: var(--border);">@i</a>
                }
                else if (i == Model.Page - 2 || i == Model.Page + 2)
                {
                    <span class="w-10 h-10 flex items-center justify-center text-sm" style="color: var(--muted-foreground);">…</span>
                }
            }
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page + 1)@baseQuery"
                   class="w-10 h-10 rounded-xl border flex items-center justify-center hover:opacity-80"
                   style="background: var(--card); border-color: var(--border);">
                    <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>
    }
</div>
