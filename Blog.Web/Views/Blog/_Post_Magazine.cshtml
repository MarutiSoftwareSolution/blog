@model Blog.Core.Domain.Post
@{
    var blogLayout = (string)(ViewBag.BlogLayout ?? "Magazine");
}

<!-- Magazine layout: centered, no sidebar, modern card styling -->
<article class="max-w-4xl mx-auto px-4 py-8 lg:py-14">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--muted-foreground);">
        <a href="/" class="hover:opacity-80">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        @if (Model.Categories.Any())
        {
            <a href="/?category=@Model.Categories.First().Slug" class="hover:opacity-80">@Model.Categories.First().Name</a>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        }
        <span class="truncate">@Model.Title</span>
    </nav>

    <!-- Article Header -->
    <header class="mb-10 text-center">
        @if (Model.Categories.Any())
        {
            <div class="flex justify-center gap-2 mb-4">
                @foreach (var cat in Model.Categories)
                {
                    <a href="/?category=@cat.Slug" class="text-xs uppercase font-bold px-3 py-1 rounded-full hover:opacity-80" style="background: var(--primary); color: var(--primary-foreground);">@cat.Name</a>
                }
            </div>
        }

        <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-tight" style="color: var(--foreground);">@Model.Title</h1>

        <div class="flex items-center justify-center gap-4 text-sm" style="color: var(--muted-foreground);">
            <div class="flex items-center gap-2">
                @{
                    var authorImg = !string.IsNullOrEmpty(Model.AvatarUrl)
                        ? Model.AvatarUrl
                        : $"https://api.dicebear.com/9.x/initials/webp?seed={System.Net.WebUtility.UrlEncode(string.IsNullOrEmpty(Model.AuthorName) ? "A" : Model.AuthorName)}&backgroundColor=e5e5e5";
                }
                <img src="@authorImg" alt="@Model.AuthorName" class="w-10 h-10 rounded-full object-cover border-2" style="border-color: var(--border);" />
                <div class="text-left">
                    <span class="block font-semibold text-sm" style="color: var(--foreground);">@(string.IsNullOrEmpty(Model.AuthorName) ? "Anonymous" : Model.AuthorName)</span>
                    <span class="text-xs">@Model.PublishedAt?.ToString("MMMM d, yyyy") · @Model.ViewCount views</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Featured Image -->
    @if (!string.IsNullOrEmpty(Model.FeatureImage))
    {
        <div class="mb-10 overflow-hidden rounded-2xl shadow-lg">
            <img src="@Model.FeatureImage" alt="@Model.Title" class="w-full h-auto object-cover" />
        </div>
    }

    <!-- Post Content -->
    <div class="post-prose mb-10" style="font-family: var(--font-body); line-height: 1.9; font-size: 1.1rem;">
        @Html.Raw(Model.Html)
    </div>

    <!-- Tags -->
    @if (Model.Tags.Any())
    {
        <div class="pt-8 border-t" style="border-color: var(--border);">
            <div class="flex flex-wrap gap-2">
                @foreach (var tag in Model.Tags)
                {
                    <a href="/?tags=@tag.Slug" class="py-1.5 px-4 text-sm rounded-full border hover:shadow-sm transition-shadow" style="background: var(--card); border-color: var(--border); color: var(--foreground);">#@tag.Name</a>
                }
            </div>
        </div>
    }

    <!-- Share -->
    <div class="flex items-center justify-center gap-4 mt-8 pt-8 border-t" style="border-color: var(--border);">
        <span class="text-sm font-medium" style="color: var(--muted-foreground);">Share this article:</span>
        <a href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)&text=@Uri.EscapeDataString(Model.Title)" target="_blank" class="w-10 h-10 rounded-full flex items-center justify-center border hover:shadow-sm transition-shadow" style="border-color: var(--border);"><i class="bi bi-twitter-x"></i></a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)" target="_blank" class="w-10 h-10 rounded-full flex items-center justify-center border hover:shadow-sm transition-shadow" style="border-color: var(--border);"><i class="bi bi-facebook"></i></a>
        <a href="https://www.linkedin.com/shareArticle?mini=true&url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)&title=@Uri.EscapeDataString(Model.Title)" target="_blank" class="w-10 h-10 rounded-full flex items-center justify-center border hover:shadow-sm transition-shadow" style="border-color: var(--border);"><i class="bi bi-linkedin"></i></a>
    </div>
</article>
