@model Blog.Core.Domain.Page

<!-- Magazine: centered, modern, rounded -->
<div class="max-w-4xl mx-auto px-4 py-8 lg:py-14">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--muted-foreground);">
        <a href="/" class="hover:opacity-80">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span>@Model.Title</span>
    </nav>

    <article>
        <header class="mb-10 text-center">
            <h1 class="text-3xl md:text-5xl font-bold leading-tight" style="color: var(--foreground);">@Model.Title</h1>
        </header>

        @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
        {
            <div class="mb-10 overflow-hidden rounded-2xl shadow-lg">
                <img src="@Model.FeaturedImageUrl" alt="@Model.Title" class="w-full h-auto object-cover" />
            </div>
        }

        <div class="post-prose" style="font-family: var(--font-body); line-height: 1.9; font-size: 1.1rem;">
            @Html.Raw(Model.Content)
        </div>
    </article>
</div>
