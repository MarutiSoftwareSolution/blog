@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();

    string GetToggleUrl(string type, string slug)
    {
        var currentCats = new List<string>(selectedCategories);
        var currentTags = new List<string>(selectedTags);
        if (type == "category") { if (currentCats.Contains(slug)) currentCats.Remove(slug); else currentCats.Add(slug); }
        else if (type == "tags") { if (currentTags.Contains(slug)) currentTags.Remove(slug); else currentTags.Add(slug); }
        var q = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) q.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (currentCats.Any()) q.Add("category=" + string.Join(",", currentCats));
        if (currentTags.Any()) q.Add("tags=" + string.Join(",", currentTags));
        return q.Any() ? "?" + string.Join("&", q) : "/";
    }
}

<div class="container xl:max-w-3xl mx-auto px-4 py-12 md:py-20">

    @* Active filters *@
    @if (!string.IsNullOrEmpty(searchTerm) || selectedCategories.Any() || selectedTags.Any())
    {
        <div class="flex items-center gap-3 mb-10 text-sm" style="color: var(--muted-foreground);">
            <span class="uppercase tracking-widest text-xs font-bold">Filtering:</span>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <span>"@searchTerm"</span>
            }
            @if (selectedCategories.Any())
            {
                <span class="font-semibold" style="color: var(--foreground);">@string.Join(", ", selectedCategories)</span>
            }
            <a href="/" class="ml-auto underline underline-offset-2 hover:opacity-50">Clear all</a>
        </div>
    }

    @* ── FILTER BOX ─────────────────────────────────────────────── *@
    @if ((ViewBag.Categories != null && ((IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories).Any()) || 
         (ViewBag.Tags != null && ((IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags).Any()))
    {
        <div class="mb-14 border rounded-lg p-6 shadow-sm flex flex-col gap-6" style="background: var(--card); border-color: var(--border);">
            <div class="flex justify-between items-center pb-4 border-b" style="border-color: var(--border);">
                <h3 class="text-xs uppercase tracking-[0.2em] font-bold" style="color: var(--foreground);">Filter Stories</h3>
                @if (selectedCategories.Any() || selectedTags.Any()) {
                    <a href="/" class="text-[10px] font-bold uppercase tracking-wider underline hover:opacity-50 text-red-500">Clear All</a>
                }
            </div>
            
            <div class="flex flex-col md:flex-row gap-10">
                @if (ViewBag.Categories != null && ((IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories).Any())
                {
                    <div class="flex-1">
                        <p class="text-[10px] uppercase tracking-[0.2em] font-bold mb-3" style="color: var(--muted-foreground);">Categories</p>
                        <div class="flex flex-wrap gap-2">
                            <a href="/" class="px-3 py-1 text-xs font-semibold border transition-all hover:opacity-70" 
                               style="background: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--foreground)" : "transparent"); color: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--background)" : "var(--foreground)"); border-color: var(--border);">All</a>
                            @foreach (var cat in (IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories)
                            {
                                bool isSelCat = selectedCategories.Contains(cat.Slug);
                                <a href="@GetToggleUrl("category", cat.Slug)" class="px-3 py-1 text-xs font-semibold border transition-all hover:opacity-70"
                                   style="background: @(isSelCat ? "var(--foreground)" : "transparent"); color: @(isSelCat ? "var(--background)" : "var(--foreground)"); border-color: var(--border);">
                                    @cat.Name
                                </a>
                            }
                        </div>
                    </div>
                }
                
                @if (ViewBag.Tags != null && ((IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags).Any())
                {
                    <div class="flex-1">
                        <p class="text-[10px] uppercase tracking-[0.2em] font-bold mb-3" style="color: var(--muted-foreground);">Topics</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var tag in (IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags)
                            {
                                bool isSelTag = selectedTags.Contains(tag.Slug);
                                <a href="@GetToggleUrl("tags", tag.Slug)" class="px-3 py-1 text-xs font-semibold border transition-all hover:opacity-70"
                                   style="background: @(isSelTag ? "var(--foreground)" : "transparent"); color: @(isSelTag ? "var(--background)" : "var(--foreground)"); border-color: var(--border);">
                                    #@tag.Name
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── POST LIST ───────────────────────────────────────────────── *@
    @if (!Model.Items.Any())
    {
        <div class="py-20 text-center">
            <p class="text-6xl mb-6 opacity-20">◌</p>
            <h3 class="text-3xl font-bold mb-2">Nothing Found</h3>
            <p style="color: var(--muted-foreground);">Try a different search or browse all posts.</p>
            <a href="/" class="inline-block mt-6 underline underline-offset-4 hover:opacity-50" style="color: var(--primary);">← All Posts</a>
        </div>
    }
    else
    {
        <div class="flex flex-col">
            @{int idx = 0;}
            @foreach (var post in Model.Items)
            {
                idx++;
                <article class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 py-8 border-b transition-all duration-200 hover:px-4 group"
                         style="border-color: var(--border);">
                    <div class="flex-1 min-w-0 flex flex-col gap-2">
                        @if (post.Categories != null && post.Categories.Any())
                        {
                            <a href="/?category=@post.Categories.First().Slug"
                               class="text-[10px] font-black uppercase tracking-[0.2em] hover:opacity-60 transition-opacity"
                               style="color: var(--primary);">
                                @post.Categories.First().Name
                            </a>
                        }
                        <h2 class="text-xl md:text-2xl font-bold leading-snug group-hover:opacity-70 transition-opacity">
                            <a href="/@post.Slug" style="color: var(--card-foreground);">@post.Title</a>
                        </h2>
                        @if (!string.IsNullOrEmpty(post.MetaDescription))
                        {
                            <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--muted-foreground);">@post.MetaDescription</p>
                        }
                    </div>
                    <div class="flex-shrink-0 text-right flex flex-col items-end gap-1">
                        <time class="text-xs font-mono font-semibold uppercase tracking-wider block" style="color: var(--muted-foreground);">
                            @post.PublishedAt?.ToString("MMM dd")
                        </time>
                        <time class="text-2xl font-black leading-none" style="color: var(--border);">
                            @post.PublishedAt?.ToString("yyyy")
                        </time>
                        <a href="/@post.Slug" class="text-xs mt-2 font-bold uppercase tracking-widest underline underline-offset-2 hover:opacity-50 transition-opacity"
                           style="color: var(--primary);">Read →</a>
                    </div>
                </article>
            }
        </div>
    }


    @* ── PAGINATION ──────────────────────────────────────────────── *@
    @if (Model.TotalPages > 1)
    {
        var qParts = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
        if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
        var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";

        <div class="mt-16 flex items-center justify-between">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page - 1)@baseQuery" class="text-sm font-black uppercase tracking-widest underline underline-offset-4 hover:opacity-50"
                   style="color: var(--foreground);">← Newer</a>
            }
            else { <span></span> }

            <span class="text-xs uppercase tracking-widest font-bold" style="color: var(--muted-foreground);">
                @Model.Page / @Model.TotalPages
            </span>

            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page + 1)@baseQuery" class="text-sm font-black uppercase tracking-widest underline underline-offset-4 hover:opacity-50"
                   style="color: var(--foreground);">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
