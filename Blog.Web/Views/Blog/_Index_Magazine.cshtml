@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    var popularPosts = ViewBag.PopularPosts as List<Blog.Core.Domain.Post> ?? new List<Blog.Core.Domain.Post>();

    var isFirstPage = Model.Page == 1 && !selectedCategories.Any() && !selectedTags.Any() && string.IsNullOrEmpty(searchTerm);
    var heroPost = (isFirstPage && Model.Items.Count >= 4) ? Model.Items.FirstOrDefault() : null;
    var gridPosts = heroPost != null ? Model.Items.Skip(1) : Model.Items;

    string GetToggleUrl(string type, string slug)
    {
        var currentCats = new List<string>(selectedCategories);
        var currentTags = new List<string>(selectedTags);
        if (type == "category") { if (currentCats.Contains(slug)) currentCats.Remove(slug); else currentCats.Add(slug); }
        else if (type == "tags") { if (currentTags.Contains(slug)) currentTags.Remove(slug); else currentTags.Add(slug); }
        var q = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) q.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (currentCats.Any()) q.Add("category=" + string.Join(",", currentCats));
        if (currentTags.Any()) q.Add("tags=" + string.Join(",", currentTags));
        return q.Any() ? "?" + string.Join("&", q) : "/";
    }
}

<div class="container xl:max-w-6xl mx-auto px-4 py-8">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div class="mb-6 flex items-center gap-3">
            <span class="text-sm" style="color: var(--muted-foreground);">Results for:</span>
            <span class="font-bold text-lg">"@searchTerm"</span>
            <a href="/" class="text-xs px-3 py-1 rounded-full border hover:opacity-80" style="border-color: var(--border);">Clear</a>
        </div>
    }

    @* Hero Featured Post *@
    @if (heroPost != null)
    {
        <a href="/@heroPost.Slug" class="group block mb-10">
            <div class="relative overflow-hidden rounded-2xl aspect-[2/1] md:aspect-[3/1]" style="background: var(--muted);">
                @if (!string.IsNullOrEmpty(heroPost.FeatureImage))
                {
                    <img src="@heroPost.FeatureImage" alt="@heroPost.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                }
                <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10">
                    @if (heroPost.Categories.Any())
                    {
                        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold mb-3" style="background: var(--primary); color: var(--primary-foreground);">@heroPost.Categories.First().Name</span>
                    }
                    <h1 class="text-2xl md:text-4xl font-bold text-white mb-2">@heroPost.Title</h1>
                    <div class="flex items-center gap-3 text-sm text-white/70">
                        <span>@(string.IsNullOrEmpty(heroPost.AuthorName) ? "Anonymous" : heroPost.AuthorName)</span>
                        <span>•</span>
                        <span>@heroPost.PublishedAt?.ToString("MMM d, yyyy")</span>
                    </div>
                </div>
            </div>
        </a>
    }

    @* ── FILTER BOX ─────────────────────────────────────────────── *@
    @if ((ViewBag.Categories != null && ((IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories).Any()) || 
         (ViewBag.Tags != null && ((IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags).Any()))
    {
        <div class="mb-10 border rounded-2xl overflow-hidden shadow-sm" style="background: var(--card); border-color: var(--border);">
            <div class="px-6 py-4 border-b flex justify-between items-center" style="border-color: var(--border); background: var(--muted)/30;">
                <h3 class="font-bold uppercase tracking-wider text-xs flex items-center gap-2">
                    <i class="bi bi-funnel"></i> Filter
                </h3>
                @if (selectedCategories.Any() || selectedTags.Any()) {
                    <a href="/" class="text-[10px] font-bold uppercase underline hover:opacity-70 text-red-500">Clear All</a>
                }
            </div>
            
            <div class="p-6 flex flex-col md:flex-row gap-8">
                @if (ViewBag.Categories != null)
                {
                    var cats = (IEnumerable<Blog.Core.Domain.Category>)ViewBag.Categories;
                    if (cats.Any())
                    {
                        <div class="flex-1">
                            <h4 class="text-xs uppercase font-bold mb-3" style="color: var(--muted-foreground);">Categories</h4>
                            <div class="flex flex-wrap gap-2">
                                <a href="/" class="px-4 py-1.5 rounded-full text-sm font-medium border @((!selectedCategories.Any() && !selectedTags.Any()) ? "shadow-sm" : "")" style="background: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--primary)" : "var(--card)"); color: @((!selectedCategories.Any() && !selectedTags.Any()) ? "var(--primary-foreground)" : "var(--foreground)"); border-color: var(--border);">All</a>
                                @foreach (var cat in cats)
                                {
                                    bool isOn = selectedCategories.Contains(cat.Slug);
                                    <a href="@GetToggleUrl("category", cat.Slug)" class="px-4 py-1.5 rounded-full text-sm font-medium border @(isOn ? "shadow-sm" : "")" style="background: @(isOn ? "var(--primary)" : "var(--card)"); color: @(isOn ? "var(--primary-foreground)" : "var(--foreground)"); border-color: var(--border);">@cat.Name</a>
                                }
                            </div>
                        </div>
                    }
                }
                
                @if (ViewBag.Tags != null)
                {
                    var tags = (IEnumerable<Blog.Core.Domain.Tag>)ViewBag.Tags;
                    if (tags.Any())
                    {
                        <div class="flex-1">
                            <h4 class="text-xs uppercase font-bold mb-3" style="color: var(--muted-foreground);">Tags</h4>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var tag in tags)
                                {
                                    bool isSelTag = selectedTags.Contains(tag.Slug);
                                    <a href="@GetToggleUrl("tags", tag.Slug)" class="px-3 py-1.5 rounded-full text-xs font-semibold border @(isSelTag ? "shadow-sm" : "")" style="background: @(isSelTag ? "var(--foreground)" : "transparent"); color: @(isSelTag ? "var(--background)" : "var(--muted-foreground)"); border-color: var(--border);">#@tag.Name</a>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="py-20 text-center">
            <i class="bi bi-journal-text text-5xl mb-4 block" style="color: var(--muted-foreground);"></i>
            <h2 class="text-2xl font-bold mb-2">No stories yet</h2>
            <p style="color: var(--muted-foreground);">The journey begins with a single word.</p>
        </div>
    }
    else
    {
        @* Post Grid *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in gridPosts)
            {
                <partial name="_PostCard" model="post" />
            }
        </div>
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        var qParts = new List<string>();
        if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
        if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
        if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
        var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";

        <div class="flex items-center justify-center gap-2 mt-10">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page - 1)@baseQuery" class="px-4 py-2 rounded-lg border text-sm font-medium hover:opacity-80" style="border-color: var(--border);">
                    <i class="bi bi-arrow-left me-1"></i>Newer
                </a>
            }
            <span class="px-4 py-2 text-sm" style="color: var(--muted-foreground);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page + 1)@baseQuery" class="px-4 py-2 rounded-lg border text-sm font-medium hover:opacity-80" style="border-color: var(--border);">
                    Older<i class="bi bi-arrow-right ms-1"></i>
                </a>
            }
        </div>
    }
</div>
