@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Something went wrong";
}

<div class="flex flex-col items-center justify-center min-h-[50vh] text-center px-4">
    <div class="mb-4">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-destructive mx-auto">
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
        </svg>
    </div>
    
    <h2 class="text-3xl font-bold text-foreground mb-4">Oops!</h2>
    <p class="text-muted-foreground max-w-lg mx-auto mb-8">
        We encountered an unexpected error while processing your request. Please try again later.
    </p>

    <div class="flex items-center gap-4 justify-center">
        <a href="/" class="px-6 py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-md font-medium shadow-sm transition-colors">
            Return to Homepage
        </a>
    </div>
</div>
