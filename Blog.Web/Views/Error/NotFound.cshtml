@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "404 - Page Not Found";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="mb-8">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-primary/20 mx-auto">
            <path d="m15 9-6 6"/><path d="m9 9 6 6"/><circle cx="12" cy="12" r="10"/>
        </svg>
    </div>
    
    <h1 class="text-6xl font-black text-foreground mb-4 tabular-nums tracking-tighter">404</h1>
    <h2 class="text-2xl font-bold text-foreground mb-4">Page not found</h2>
    <p class="text-muted-foreground max-w-md mx-auto mb-8">
        Sorry, we couldn't find the page you're looking for. It might have been moved or doesn't exist anymore.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <button onclick="window.history.back()" class="px-6 py-2.5 bg-secondary text-secondary-foreground hover:bg-secondary/80 rounded-md font-medium transition-colors flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Go Back
        </button>
        <a href="/" class="px-6 py-2.5 bg-primary text-primary-foreground hover:bg-primary/90 rounded-md font-medium shadow-sm transition-colors flex items-center gap-2">
            Home Page
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
    </div>
</div>
