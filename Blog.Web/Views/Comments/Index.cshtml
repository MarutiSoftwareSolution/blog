@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Comment>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Comments";

    Func<string, string> GetTabClass = (status) => 
        (ViewBag.StatusFilter as string) == status
        ? "border-primary text-primary whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
        : "border-transparent text-muted-foreground hover:text-foreground hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm";
}

<div class="space-y-6">
    <!-- Filter Tabs -->
    <div class="border-b border-border">
        <nav class="-mb-px flex gap-6" aria-label="Tabs">
            <a href="?status=pending" class="@GetTabClass("pending")">Pending</a>
            <a href="?status=approved" class="@GetTabClass("approved")">Approved</a>
        </nav>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="bg-card rounded-lg border border-border p-12 text-center text-muted-foreground">
             <div class="bg-muted w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="text-lg font-medium text-foreground mb-1">No comments found</h3>
            <p>This list is empty.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var comment in Model.Items)
            {
                <div class="bg-card rounded-lg border border-border p-4 shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-start gap-4">
                        <div class="flex-shrink-0">
                            <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-secondary-foreground font-semibold">
                                @(string.IsNullOrEmpty(comment.AuthorName) ? "?" : comment.AuthorName.Substring(0, 1))
                            </div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between flex-wrap gap-2">
                                <div>
                                    <h4 class="text-sm font-semibold text-foreground">@comment.AuthorName</h4>
                                    <p class="text-xs text-muted-foreground">@comment.AuthorEmail</p>
                                </div>
                                <span class="text-xs text-muted-foreground" title="@comment.CreatedAt">
                                    @comment.CreatedAt.ToString("MMM d, yyyy HH:mm")
                                </span>
                            </div>

                            <div class="mt-2 text-sm text-foreground prose-sm max-w-none">
                                <p>@comment.Content</p>
                            </div>

                            <div class="mt-2 text-xs text-muted-foreground">
                                on <a href="/@comment.PostSlug" target="_blank" class="hover:underline text-primary">@comment.PostTitle</a>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-2">
                                @if (comment.Status != Blog.Core.Domain.CommentStatus.Approved)
                                {
                                    <form method="post" action="/admin/comments/approve/@comment.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-100 text-green-700 hover:bg-green-200 rounded text-xs font-medium transition-colors">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                            Approve
                                        </button>
                                    </form>
                                }
                                
                                @if (comment.Status != Blog.Core.Domain.CommentStatus.Pending)
                                {
                                    <form method="post" action="/admin/comments/pending/@comment.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-100 text-blue-700 hover:bg-blue-200 rounded text-xs font-medium transition-colors">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            Pending
                                        </button>
                                    </form>
                                }

                                <form method="post" action="/admin/comments/delete/@comment.Id" onsubmit="return confirm('Delete permanently?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-100 text-red-700 hover:bg-red-200 rounded text-xs font-medium transition-colors">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="mt-6 flex justify-center gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?status=@ViewBag.StatusFilter&page=@i" 
                       class="px-3 py-1 text-sm rounded-md border transition-colors
                       @(i == Model.Page 
                           ? "bg-primary text-primary-foreground border-primary" 
                           : "bg-background text-foreground border-input hover:bg-accent hover:text-accent-foreground")">
                        @i
                    </a>
                }
            </div>
        }
    }
</div>
