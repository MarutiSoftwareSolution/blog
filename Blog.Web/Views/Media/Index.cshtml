@model List<Blog.Core.Domain.Media>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Media Library";
}

<div class="space-y-6">
    @* <!-- Upload Area -->@Html.AntiForgeryToken() *@
    <div id="uploadZone" class="border-2 border-dashed border-border rounded-lg p-12 text-center hover:bg-muted/50 transition-all cursor-pointer relative group">
        <input type="file" id="fileInput" multiple accept="image/*,video/mp4,video/webm,application/pdf,.doc,.docx,.xls,.xlsx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
        <div class="space-y-4">
            <div class="w-16 h-16 bg-muted text-muted-foreground rounded-full flex items-center justify-center mx-auto group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            </div>
            <div>
                <h3 class="text-lg font-medium text-foreground">Click to upload or drag and drop</h3>
                <p class="text-muted-foreground text-sm mt-1">SVG, PNG, JPG or GIF (max. 10MB)</p>
            </div>
        </div>
        <!-- Progress Bar (Hidden by default) -->
        <div id="uploadProgress" class="hidden mt-6 max-w-sm mx-auto">
             <div class="flex justify-between text-xs text-muted-foreground mb-1">
                <span id="progressLabel">Uploading...</span>
                <span id="progressPercent">0%</span>
            </div>
            <div class="w-full bg-muted rounded-full h-2.5 overflow-hidden">
                <div id="progressFill" class="bg-primary h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
        </div>
    </div>

    <!-- Media Grid -->
    <div x-data="{ tab: 'all' }">
        <div class="flex items-center gap-4 mb-6 border-b border-border relative">
            <h2 class="text-lg font-semibold mr-4 py-2">Library Items</h2>
            <button @@click="tab = 'all'"     class="px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px" :class="tab === 'all' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'">All</button>
            <button @@click="tab = 'images'"  class="px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px" :class="tab === 'images' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'">General</button>
            <button @@click="tab = 'og'"      class="px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px" :class="tab === 'og' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'">Open Graph</button>
            <button @@click="tab = 'twitter'" class="px-4 py-2 text-sm font-medium border-b-2 transition-colors -mb-px" :class="tab === 'twitter' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'">Twitter Cards</button>
        </div>
        
        @if (!Model.Any())
        {
             <div class="text-center py-12 text-muted-foreground bg-muted/20 rounded-lg border border-border/50">
                <svg class="mx-auto h-12 w-12 text-muted-foreground/50 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <p>No media files uploaded yet.</p>
            </div>
        }
        else
        {
            <div id="mediaGrid" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                @foreach (var item in Model)
                {
                    string folderType = "images";
                    if (item.FilePath != null && item.FilePath.Contains("/og/", StringComparison.OrdinalIgnoreCase)) folderType = "og";
                    else if (item.FilePath != null && item.FilePath.Contains("/twitter/", StringComparison.OrdinalIgnoreCase)) folderType = "twitter";

                    <div class="group relative aspect-square bg-muted rounded-lg overflow-hidden border border-border"
                         x-show="tab === 'all' || tab === '@folderType'"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         style="display: none;" x-init="$el.style.display = 'block'">
                        @{ var cType = item.ContentType ?? ""; var name = item.FileName ?? ""; }
                        @if (cType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".gif", StringComparison.OrdinalIgnoreCase))
                        {
                            <img src="@item.Url" alt="@item.AltText" loading="lazy" class="w-full h-full object-cover transition-transform group-hover:scale-105" />
                        }
                        else
                        {
                            <div class="w-full h-full flex flex-col items-center justify-center text-muted-foreground p-4">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span class="text-xs font-mono mt-2 uppercase">@System.IO.Path.GetExtension(item.FileName ?? "").TrimStart('.')</span>
                            </div>
                        }
                        
                         <!-- Overlay -->
                        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-3">
                            <p class="text-white text-xs truncate mb-2" title="@item.OriginalFileName">@item.OriginalFileName</p>
                            <div class="flex items-center gap-2">
                                <button onclick="copyToClipboard('@item.Url')" class="flex-1 px-2 py-1 bg-white/20 hover:bg-white/30 text-white text-xs rounded backdrop-blur-sm transition-colors text-center">
                                    Copy URL
                                </button>
                                <form method="post" action="/admin/media/delete/@item.Id" onsubmit="return confirm('Delete file?')" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="p-1 bg-red-500/80 hover:bg-red-500 text-white rounded transition-colors" title="Delete">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const progress = document.getElementById('uploadProgress');
    const progressFill = document.getElementById('progressFill');
    const progressLabel = document.getElementById('progressLabel');
    const progressPercent = document.getElementById('progressPercent');

    fileInput.addEventListener('change', handleFiles);

    // Drag and drop visual feedback
    uploadZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadZone.classList.add('border-primary', 'bg-primary/5');
    });

    uploadZone.addEventListener('dragleave', () => {
        uploadZone.classList.remove('border-primary', 'bg-primary/5');
    });

    uploadZone.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadZone.classList.remove('border-primary', 'bg-primary/5');
        if (e.dataTransfer.files.length) {
            handleUpload(e.dataTransfer.files);
        }
    });

    function handleFiles(e) {
        if (e.target.files.length) {
            handleUpload(e.target.files);
        }
    }

            async function handleUpload(files) {
            progress.classList.remove('hidden');
            // Grab the token from the hidden input we just added at the top
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            let completed = 0;
            let hasErrors = false;
            const total = files.length;

            for (let i = 0; i < total; i++) {
                const file = files[i];
                progressLabel.textContent = `Uploading ${file.name}...`;

                const formData = new FormData();
                formData.append('file', file);

                // FIX: Append the token directly to the FormData, NOT the headers
                if (token) {
                    formData.append('__RequestVerificationToken', token);
                }

                try {
                    // FIX: Removed the custom 'headers' entirely.
                    // The browser will automatically set the correct multipart/form-data headers.
                    const response = await fetch('/admin/Media/upload', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        hasErrors = true;
                        console.error(`Server rejected file ${file.name} with status ${response.status}`);
                    }
                } catch (error) {
                    hasErrors = true;
                    console.error('Network or fetch error for file', file.name, error);
                }

                completed++;
                const pct = Math.round((completed / total) * 100);
                progressFill.style.width = pct + '%';
                progressPercent.textContent = pct + '%';
            }

            if (!hasErrors) {
                progressLabel.textContent = 'Upload Complete!';
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            } else {
                progressLabel.textContent = 'Finished with errors. Check F12 Console.';
                progressFill.classList.remove('bg-primary');
                progressFill.classList.add('bg-red-500');
            }
        }

    function copyToClipboard(text) {
        navigator.clipboard.writeText(window.location.origin + text).then(() => {
            // Could show a toast notification here
            alert('URL Copied!'); 
        });
    }
</script>
}
