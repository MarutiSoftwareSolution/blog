@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Complete Setup";
}
<style>
    .setup-card {
        max-width: 500px;
        margin: 60px auto;
        background: #1a1d2e;
        border: 1px solid #2a2d3e;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }
    .setup-card h2 { color: #fff; font-size: 1.4rem; margin-bottom: 8px; }
    .setup-card p { color: #8b8fa8; font-size: 0.9rem; margin-bottom: 28px; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; color: #9ca3af; font-size: 0.8rem; font-weight: 500; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-group input { width: 100%; padding: 11px 14px; background: #0f1117; border: 1px solid #2a2d3e; border-radius: 8px; color: #fff; font-size: 0.95rem; outline: none; transition: border-color 0.2s; }
    .form-group input:focus { border-color: #6366f1; }
    .current-email { background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3); border-radius: 8px; padding: 10px 14px; color: #a5b4fc; font-size: 0.875rem; margin-bottom: 24px; }
    .btn-save { padding: 12px 28px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; border-radius: 8px; color: #fff; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
    .btn-save:hover { opacity: 0.9; }
    .btn-skip { padding: 12px 20px; background: transparent; border: 1px solid #2a2d3e; border-radius: 8px; color: #8b8fa8; font-size: 0.95rem; cursor: pointer; margin-left: 10px; text-decoration: none; display: inline-block; }
    .error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; border-radius: 8px; padding: 12px 16px; font-size: 0.875rem; margin-bottom: 20px; }
    .hint { color: #6b7280; font-size: 0.8rem; margin-top: 5px; }
</style>

<div class="setup-card">
    <h2>🎉 You're in! Complete your setup</h2>
    <p>You're logged in with temporary credentials. Set your permanent email and password below, or skip and do it later from Settings.</p>

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="error">@ViewBag.Error</div>
    }

    <div class="current-email">
        Current email: <strong>@ViewBag.CurrentEmail</strong>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>New Email</label>
            <input type="email" name="email" value="@ViewBag.CurrentEmail" required />
        </div>
        <div class="form-group">
            <label>New Password</label>
            <input type="password" name="password" placeholder="Minimum 8 characters" />
            <div class="hint">Leave blank to keep the current password</div>
        </div>
        <div class="form-group">
            <label>Confirm Password</label>
            <input type="password" name="confirmPassword" placeholder="Repeat password" />
        </div>
        <div style="margin-top: 24px;">
            <button type="submit" class="btn-save">Save & Continue →</button>
            <a href="/admin/dashboard" class="btn-skip">Skip for now</a>
        </div>
    </form>
</div>
