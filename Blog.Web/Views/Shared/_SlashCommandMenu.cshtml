    display:inline-flex; align-items:center; padding:1px 4px;
    border:1px solid var(--border,#dde1e6); border-radius:3px;
    font-size:10px; font-family:monospace;
    background:var(--muted,#f8fafc); color:var(--foreground,#374151);
}

/* ── Empty ──────────────────────────────────────────────────────── */
.slash-menu-empty { padding:18px; text-align:center; font-size:13px; color:var(--muted-foreground,#94a3b8); }

/* ────────────────────────────────────────────────────────────────── */
/* SLASH INPUT DIALOG                                                  */
/* ────────────────────────────────────────────────────────────────── */
#slash-input-dialog {
    background:var(--card,#fff);
    border:1px solid var(--border,#e2e8f0);
    border-radius:10px;
    box-shadow:0 12px 40px rgba(0,0,0,.18), 0 2px 10px rgba(0,0,0,.08);
    width:320px;
    overflow:hidden;
    animation:slashIn .14s cubic-bezier(.22,1,.36,1) both;
}
.sid-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:12px 14px 10px;
    border-bottom:1px solid var(--border,#e2e8f0);
}
.sid-title { font-size:14px; font-weight:600; color:var(--foreground,#1a1a2e); }
.sid-close {
    border:none; background:none; cursor:pointer; padding:2px 5px;
