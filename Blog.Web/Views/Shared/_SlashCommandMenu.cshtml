<!-- ═══════════════════════════════════════════════════════════════════
     SLASH COMMAND MENU  — focus stays in Quill at all times
     ═══════════════════════════════════════════════════════════════════ -->
<div id="slash-menu" style="display:none; position:fixed; z-index:9999;" role="listbox">
    <div class="slash-menu-header">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
             style="opacity:.45;flex-shrink:0">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <span id="slash-menu-query" class="slash-menu-query-echo">Type to filter…</span>
    </div>
    <div id="slash-menu-list" class="slash-menu-list"></div>
    <div class="slash-menu-footer">
        <span><kbd>↑↓</kbd> Navigate</span>
        <span><kbd>↵</kbd> Select</span>
        <span><kbd>Esc</kbd> Dismiss</span>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════
     SLASH INPUT DIALOG  — replaces browser prompt() for inputs
     ═══════════════════════════════════════════════════════════════════ -->
<div id="slash-input-dialog" style="display:none; position:fixed; z-index:10000;">
    <div class="sid-header">
        <span class="sid-title" id="sid-title">Insert</span>
        <button class="sid-close" id="sid-close" type="button">&#x2715;</button>
    </div>
    <div class="sid-body" id="sid-body"></div>
    <div class="sid-footer">
        <button class="sid-btn sid-cancel" id="sid-cancel" type="button">Cancel</button>
        <button class="sid-btn sid-confirm" id="sid-confirm" type="button">Insert</button>
    </div>
</div>

<style>
/* ── Slash Menu Container ────────────────────────────────────────── */
#slash-menu {
    background: var(--card,#fff);
    border: 1px solid var(--border,#e2e8f0);
    border-radius: 10px;
    box-shadow: 0 8px 32px rgba(0,0,0,.15), 0 2px 8px rgba(0,0,0,.07);
    width: 300px;
    max-height: 380px;
    display: flex; flex-direction: column;
    overflow: hidden;
    pointer-events: auto;
}
#slash-menu.slash-animate-in {
    animation: slashIn .14s cubic-bezier(.22,1,.36,1) both;
}
@@keyframes slashIn {
    from { opacity:0; transform:scale(.95) translateY(-4px); }
    to   { opacity:1; transform:scale(1)   translateY(0);    }
}

/* ── Header ─────────────────────────────────────────────────────── */
.slash-menu-header {
    display:flex; align-items:center; gap:7px;
    padding:9px 12px 7px;
    border-bottom:1px solid var(--border,#e2e8f0);
    flex-shrink:0;
}
.slash-menu-query-echo {
    font-size:13px; color:var(--muted-foreground,#94a3b8);
    font-style:italic; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:220px;
}
.slash-menu-query-echo.has-text { color:var(--foreground,#1a1a2e); font-style:normal; font-weight:500; }

/* ── List ───────────────────────────────────────────────────────── */
.slash-menu-list { overflow-y:auto; flex:1; padding:5px; }
.slash-menu-list::-webkit-scrollbar { width:4px; }
.slash-menu-list::-webkit-scrollbar-track { background:transparent; }
.slash-menu-list::-webkit-scrollbar-thumb { background:var(--border,#e2e8f0); border-radius:9999px; }

/* ── Category ───────────────────────────────────────────────────── */
.slash-menu-category {
    font-size:10px; font-weight:700; letter-spacing:.07em; text-transform:uppercase;
    color:var(--muted-foreground,#94a3b8); padding:8px 8px 3px;
}

/* ── Item ───────────────────────────────────────────────────────── */
.slash-menu-item {
    display:flex; align-items:center; gap:9px; padding:6px 8px; border-radius:6px;
    cursor:pointer; transition:background .1s; user-select:none;
}
.slash-menu-item:hover { background:var(--accent,#f1f5f9); }
.slash-menu-item.active { background:var(--primary,#6366f1); color:#fff; }

/* ── Icon ───────────────────────────────────────────────────────── */
.slash-item-icon {
    width:30px; height:30px; border-radius:6px;
    border:1px solid var(--border,#e2e8f0); background:var(--background,#f8fafc);
    display:flex; align-items:center; justify-content:center;
    font-size:13px; font-weight:700; font-family:Georgia,serif; flex-shrink:0;
    transition:background .1s, border-color .1s;
}
.slash-menu-item.active .slash-item-icon { background:rgba(255,255,255,.18); border-color:rgba(255,255,255,.3); }

/* ── Text ───────────────────────────────────────────────────────── */
.slash-item-text { flex:1; min-width:0; }
.slash-item-label { font-size:13px; font-weight:500; color:var(--foreground,#1a1a2e); line-height:1.3; }
.slash-menu-item.active .slash-item-label { color:#fff; }
.slash-item-desc  { font-size:11px; color:var(--muted-foreground,#94a3b8); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.slash-menu-item.active .slash-item-desc { color:rgba(255,255,255,.75); }

/* ── Badge ──────────────────────────────────────────────────────── */
.slash-item-badge {
    font-size:10px; font-weight:600; padding:2px 5px; border-radius:4px;
    background:var(--muted,#f1f5f9); color:var(--muted-foreground,#64748b);
    flex-shrink:0; font-family:monospace;
}
.slash-menu-item.active .slash-item-badge { background:rgba(255,255,255,.9); color:var(--foreground,#1a1a2e); }

/* ── Footer ─────────────────────────────────────────────────────── */
.slash-menu-footer {
    display:flex; gap:10px; padding:5px 12px;
    border-top:1px solid var(--border,#e2e8f0);
    font-size:10px; color:var(--muted-foreground,#94a3b8); flex-shrink:0;
}
