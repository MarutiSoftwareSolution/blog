}
.sid-close:hover { background:var(--accent,#f1f5f9); color:var(--foreground,#1a1a2e); }

.sid-body { padding:14px; display:flex; flex-direction:column; gap:10px; }
.sid-field { display:flex; flex-direction:column; gap:4px; }
.sid-field label { font-size:12px; font-weight:500; color:var(--foreground,#1a1a2e); }
.sid-field input,
