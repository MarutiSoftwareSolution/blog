// ══════════════════════════════════════════════════════════════════════
//  SLASH INPUT DIALOG
// ══════════════════════════════════════════════════════════════════════
function SlashInputDialog() {
    this.el      = document.getElementById('slash-input-dialog');
    this.titleEl = document.getElementById('sid-title');
    this.bodyEl  = document.getElementById('sid-body');
    this.confirmEl = document.getElementById('sid-confirm');
    this.cancelEl  = document.getElementById('sid-cancel');
    this.closeEl   = document.getElementById('sid-close');
    this._onConfirm = null;
    this._onCancel  = null;
    this._bindEvents();
}

SlashInputDialog.prototype._bindEvents = function() {
    var self = this;
    this.confirmEl.addEventListener('mousedown', function(e){ e.preventDefault(); self._submit(); });
    this.cancelEl.addEventListener('mousedown',  function(e){ e.preventDefault(); self.hide(true); });
    this.closeEl.addEventListener('mousedown',   function(e){ e.preventDefault(); self.hide(true); });
    // Enter key inside inputs
    this.el.addEventListener('keydown', function(e){
        if (e.key === 'Enter')  { e.preventDefault(); self._submit(); }
        if (e.key === 'Escape') { e.preventDefault(); self.hide(true); }
    });
};

SlashInputDialog.prototype.show = function(config, position, onConfirm, onCancel) {
    this._onConfirm = onConfirm;
    this._onCancel  = onCancel;
    this.titleEl.textContent   = config.title      || 'Insert';
    this.confirmEl.textContent = config.confirmText || 'Insert';

    this.bodyEl.innerHTML = '';
    (config.fields || []).forEach(function(f) {
        var wrap = document.createElement('div');
        wrap.className = 'sid-field';
        var lbl  = document.createElement('label');
        lbl.textContent = f.label || f.key;
        wrap.appendChild(lbl);

        if (f.type === 'select') {
            // ── dropdown ────────────────────────────────────────────
            var sel = document.createElement('select');
            sel.setAttribute('data-key', f.key);
            (f.options || []).forEach(function(opt) {
                var o = document.createElement('option');
                o.value = opt.value;
                o.textContent = opt.label;
                if (f.default && opt.value === f.default) o.selected = true;
                sel.appendChild(o);
            });
            wrap.appendChild(sel);
        } else {
            // ── text / url input ────────────────────────────────────
            var inp = document.createElement('input');
            inp.type = f.type || 'text';
            inp.setAttribute('data-key', f.key);
            inp.placeholder = f.placeholder || '';
            inp.autocomplete = 'off';
            wrap.appendChild(inp);
        }

        this.bodyEl.appendChild(wrap);
    }, this);

    var menuW = 320;
    var left  = position.left;
    var top   = position.top;
    if (left + menuW > window.innerWidth  - 8) left = window.innerWidth  - menuW - 8;
    if (left < 8) left = 8;
    this.el.style.top  = top  + 'px';
    this.el.style.left = left + 'px';
    this.el.style.display = 'block';

    var first = this.el.querySelector('input, select');
    if (first) setTimeout(function(){ first.focus(); }, 50);
};

SlashInputDialog.prototype.hide = function(cancel) {
    this.el.style.display = 'none';
    if (cancel && this._onCancel) this._onCancel();
    this._onConfirm = null;
    this._onCancel  = null;
};

SlashInputDialog.prototype._submit = function() {
    var values = {};
    this.el.querySelectorAll('input[data-key], select[data-key]').forEach(function(el){
        values[el.getAttribute('data-key')] = el.value;
    });
    var cb = this._onConfirm;
    this.hide(false);
    if (cb) cb(values);
};

// ══════════════════════════════════════════════════════════════════════
//  SLASH MENU
// ══════════════════════════════════════════════════════════════════════
function SlashMenu(quill) {
    this.quill    = quill;
    this.menu     = document.getElementById('slash-menu');
    this.queryEl  = document.getElementById('slash-menu-query');
    this.listEl   = document.getElementById('slash-menu-list');
    this.dialog   = new SlashInputDialog();

    this.isOpen   = false;
    this.activeIdx = 0;
    this.slashIdx  = -1;
    this.query     = '';
    this.filtered  = [];
    this._menuPos  = { top:0, left:0 };

    this._bindQuillEvents();
    this._bindKeyboardNav();
    this._bindMouseClick();
}

// ── Quill events ──────────────────────────────────────────────────────
SlashMenu.prototype._bindQuillEvents = function() {
    var self = this;
    this.quill.on('text-change', function(delta, old, source) {
        if (source !== 'user') return;
        if (self.isOpen) { self._updateQuery(); }
        else             { self._checkTrigger(); }
    });
    this.quill.on('selection-change', function(range) {
        if (!self.isOpen) return;
        if (range === null) {
            setTimeout(function(){
                if (!self.menu.matches(':hover') && self.dialog.el.style.display === 'none')
                    self.close(true);
            }, 150);
            return;
        }
        if (range.index < self.slashIdx) self.close(false);
    });
};

// ── Detect "/" trigger ─────────────────────────────────────────────────
SlashMenu.prototype._checkTrigger = function() {
    var range = this.quill.getSelection();
    if (!range || range.index === 0) return;

    // The char just inserted is always at range.index - 1
    var lastChar = this.quill.getText(range.index - 1, 1);
    if (lastChar !== '/') return;

    // Trigger after: start-of-doc, newline, or a space
    // Does NOT trigger mid-word (e.g. "he/lo" is safe)
    var prevChar = range.index >= 2 ? this.quill.getText(range.index - 2, 1) : '';
    if (prevChar === '' || prevChar === '\n' || prevChar === ' ') {
        this.slashIdx = range.index - 1;
        this.query    = '';
        this.open(range.index);
    }
};

// ── Update query ───────────────────────────────────────────────────────
SlashMenu.prototype._updateQuery = function() {
    var range = this.quill.getSelection();
    if (!range) return;
    if (range.index <= this.slashIdx) { this.close(true); return; }
    var raw = this.quill.getText(this.slashIdx, range.index - this.slashIdx);
    this.query = raw.charAt(0) === '/' ? raw.slice(1) : raw;
    if (this.query.indexOf('\n') !== -1) { this.close(true); return; }
    this._filter(this.query);
    this._updateHeader(this.query);
};

// ── Open ───────────────────────────────────────────────────────────────
SlashMenu.prototype.open = function(cursorIdx) {
    this.isOpen   = true;
    this.activeIdx = 0;
    this.query    = '';
    this._filter('');
    this._updateHeader('');
    this._position(cursorIdx);
    this.menu.style.display = 'flex';
    this.menu.style.flexDirection = 'column';
    this.menu.classList.remove('slash-animate-in');
    void this.menu.offsetWidth;
    this.menu.classList.add('slash-animate-in');
};

// ── Close ──────────────────────────────────────────────────────────────
SlashMenu.prototype.close = function(deleteQuery) {
    if (!this.isOpen) return;
    this.isOpen = false;
    this.menu.style.display = 'none';
    this.menu.classList.remove('slash-animate-in');
    if (deleteQuery && this.slashIdx >= 0) {
        var range  = this.quill.getSelection();
        var endIdx = range ? range.index : this.slashIdx + 1;
        var len    = endIdx - this.slashIdx;
        if (len > 0) {
            this.quill.deleteText(this.slashIdx, len, 'user');
            this.quill.setSelection(this.slashIdx, 0, 'user');
        }
    }
    this.slashIdx = -1;
    this.quill.focus();
};

// ── Position (prefers below, flips above when near viewport bottom) ──
SlashMenu.prototype._position = function(idx) {
    var menuW = 300;
    var minH  = 180;   // min useful height before flipping direction
    var maxH  = 380;

    // Use Selection API for true viewport coords — avoids Quill getBounds()
    // adding scrollTop which breaks calculations when editor is scrolled
    var cursorBottom, cursorTop, left;

    var sel = window.getSelection();
    if (sel && sel.rangeCount > 0) {
        var r = sel.getRangeAt(0).getBoundingClientRect();
        if (r && r.width + r.height > 0) {
            cursorBottom = r.bottom;
            cursorTop    = r.top;
            left         = r.left;
        }
    }

    // Fallback: Quill getBounds corrected for scroll
    if (cursorBottom === undefined) {
        var bounds    = this.quill.getBounds(idx);
        var ctRect    = this.quill.container.getBoundingClientRect();
        var scrollTop = this.quill.container.scrollTop || 0;
        cursorBottom  = ctRect.top + bounds.bottom - scrollTop;
        cursorTop     = ctRect.top + bounds.top    - scrollTop;
        left          = ctRect.left + bounds.left;
    }

    // Clamp horizontal
    if (left + menuW > window.innerWidth - 8) left = window.innerWidth - menuW - 8;
    if (left < 8) left = 8;

    var spaceBelow = window.innerHeight - cursorBottom - 8;
    var spaceAbove = cursorTop - 8;

    var top, capH;
    if (spaceBelow >= minH) {
        // Enough room below → show beneath cursor
        top  = cursorBottom + 4;
        capH = Math.min(maxH, spaceBelow - 4);
    } else {
        // Too little room below → flip above cursor
        capH = Math.min(maxH, spaceAbove - 4);
        top  = cursorTop - capH - 4;
    }

    capH = Math.max(120, capH);

    this.menu.style.maxHeight = capH + 'px';
    this.menu.style.top  = top  + 'px';
    this.menu.style.left = left + 'px';

    this._menuPos = { top: top, left: left };
};

// ── Filter ─────────────────────────────────────────────────────────────
SlashMenu.prototype._filter = function(q) {
    var lower = q.toLowerCase().trim();
    this.filtered = lower
        ? COMMANDS.filter(function(c){
              return c.label.toLowerCase().includes(lower)
                  || c.desc.toLowerCase().includes(lower)
                  || c.badge.toLowerCase().includes(lower)
                  || c.keywords.some(function(k){ return k.includes(lower); });
          })
        : COMMANDS.slice();
    this.activeIdx = 0;
    this._render();
};

SlashMenu.prototype._updateHeader = function(q) {
    if (!this.queryEl) return;
    if (q) { this.queryEl.textContent = '/'+q; this.queryEl.classList.add('has-text'); }
    else   { this.queryEl.textContent = 'Type to filter…'; this.queryEl.classList.remove('has-text'); }
};

// ── Render ─────────────────────────────────────────────────────────────
SlashMenu.prototype._render = function() {
    var self = this;
    this.listEl.innerHTML = '';
    if (!this.filtered.length) {
        this.listEl.innerHTML = '<div class="slash-menu-empty">No commands found</div>';
        return;
    }
    var groups = {};
    this.filtered.forEach(function(cmd, i){
        if (!groups[cmd.category]) groups[cmd.category] = [];
        groups[cmd.category].push({ cmd:cmd, idx:i });
    });
    Object.keys(groups).forEach(function(cat){
        var lbl = document.createElement('div');
        lbl.className = 'slash-menu-category';
        lbl.textContent = cat;
        self.listEl.appendChild(lbl);
        groups[cat].forEach(function(entry){
            var item = document.createElement('div');
            item.className = 'slash-menu-item' + (entry.idx === self.activeIdx ? ' active' : '');
            item.setAttribute('role','option');
            item.dataset.idx = entry.idx;
            item.innerHTML =
                '<div class="slash-item-text">' +
                    '<div class="slash-item-label">' + entry.cmd.label + '</div>' +
                    '<div class="slash-item-desc">'  + entry.cmd.desc  + '</div>' +
                '</div>' +
                '<div class="slash-item-badge">' + entry.cmd.badge + '</div>';
            item.addEventListener('mousedown', function(e){
                e.preventDefault();
                self._select(entry.idx);
            });
            self.listEl.appendChild(item);
        });
    });
    this._scrollActive();
};

SlashMenu.prototype._scrollActive = function() {
    var el = this.listEl.querySelector('.slash-menu-item.active');
    if (el) el.scrollIntoView({ block:'nearest' });
};

// ── Select ─────────────────────────────────────────────────────────────
SlashMenu.prototype._select = function(idx) {
    var cmd = this.filtered[idx];
    if (!cmd) return;

    var self     = this;
    var slashIdx = this.slashIdx;
    var quill    = this.quill;
    var menuPos  = { top: this._menuPos.top, left: this._menuPos.left };

    // Remove '/' + query from editor
    var range = quill.getSelection() || { index: slashIdx + 1 };
    var len   = range.index - slashIdx;
    if (len > 0) quill.deleteText(slashIdx, len, 'user');
    quill.setSelection(slashIdx, 0, 'user');

    // Hide menu (but don't close fully yet if dialog needed)
    this.isOpen = false;
    this.slashIdx = -1;
    this.menu.style.display = 'none';

    if (cmd.inputDialog) {
        // Show input dialog, execute action on confirm
        this.dialog.show(
            cmd.inputDialog,
            menuPos,
            function(values) {
                // After dialog confirmed, execute the block insert
                setTimeout(function(){
                    var r = quill.getSelection() || { index: slashIdx };
                    cmd.action(quill, r, values);
                    quill.focus();
                }, 20);
            },
            function() {
                // Cancelled — just refocus
                quill.focus();
            }
        );
    } else {
        // No dialog — execute immediately
        setTimeout(function(){
            var r = quill.getSelection() || { index: slashIdx };
            cmd.action(quill, r);
            quill.focus();
        }, 20);
    }
};

// ── Keyboard nav (capture on quill.root) ──────────────────────────────
SlashMenu.prototype._bindKeyboardNav = function() {
    var self = this;
    this.quill.root.addEventListener('keydown', function(e) {
        if (!self.isOpen) return;
        switch (e.key) {
            case 'ArrowDown':
                e.preventDefault();
                self.activeIdx = Math.min(self.activeIdx + 1, self.filtered.length - 1);
                self._render();
                break;
            case 'ArrowUp':
                e.preventDefault();
                self.activeIdx = Math.max(self.activeIdx - 1, 0);
                self._render();
                break;
            case 'Enter':
                e.preventDefault();
                e.stopImmediatePropagation();
                self._select(self.activeIdx);
                break;
            case 'Escape':
                e.preventDefault();
                self.close(true);
                break;
        }
    }, true);
};

// ── Click outside ──────────────────────────────────────────────────────
SlashMenu.prototype._bindMouseClick = function() {
    var self = this;
    document.addEventListener('mousedown', function(e) {
        if (self.isOpen
            && !self.menu.contains(e.target)
            && e.target !== self.quill.root) {
            self.close(true);
        }
    });
};

// ══════════════════════════════════════════════════════════════════════
//  PUBLIC API
// ══════════════════════════════════════════════════════════════════════
window.initSlashMenu = function(quill) {
    return new SlashMenu(quill);
};

})();
</script>
