@inject Blog.Core.Interfaces.ISettingRepository SettingsRepo
@{
    var userSettings = await SettingsRepo.GetSettingsAsync(ViewBag.OwnerId ?? Guid.Empty);
    var siteName = userSettings.SiteName;
    var siteDescription = userSettings.SiteDescription;
    string twitter   = userSettings.SocialTwitter;
    string facebook  = userSettings.SocialFacebook;
    string instagram = userSettings.SocialInstagram;
    string youtube   = userSettings.SocialYoutube;
    string linkedin  = userSettings.SocialLinkedin;
    string github    = userSettings.SocialGithub;
}

@* MODERN footer — sharp, professional, solid primary accent bar at top, no gradient, no rounded *@
<footer style="background: var(--card); border-top: 3px solid var(--primary);">
    <div class="container xl:max-w-6xl mx-auto px-4 py-12 md:py-16">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
            @* Brand *@
            <div class="flex flex-col gap-3 max-w-sm">
                <a href="/" class="flex items-center gap-3 hover:opacity-70 transition-opacity group">
                    <div class="w-8 h-8 flex items-center justify-center text-sm font-black"
                         style="background: var(--primary); color: var(--primary-foreground);">
                        @(string.IsNullOrEmpty(siteName) ? 'B' : siteName[0])
                    </div>
                    <span class="text-lg font-bold tracking-tight" style="color: var(--foreground);">@siteName</span>
                </a>
                <p class="text-sm leading-relaxed" style="color: var(--muted-foreground);">@siteDescription</p>
            </div>
            @* Social icons — square solid filled *@
            <div class="flex flex-col gap-3">
                <span class="text-[10px] uppercase tracking-[0.2em] font-semibold" style="color: var(--muted-foreground);">Follow</span>
                <div class="flex items-center gap-2 flex-wrap">
                    <a href="/feed" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity"
                       style="background: var(--primary); color: var(--primary-foreground);" title="RSS Feed">
                        <i class="bi bi-rss-fill text-sm"></i>
                    </a>
                    @if (!string.IsNullOrEmpty(twitter))   { <a href="@twitter"   target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="X / Twitter"><i class="bi bi-twitter-x text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(facebook))  { <a href="@facebook"  target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="Facebook"><i class="bi bi-facebook text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(instagram)) { <a href="@instagram" target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="Instagram"><i class="bi bi-instagram text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(youtube))   { <a href="@youtube"   target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="YouTube"><i class="bi bi-youtube text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(linkedin))  { <a href="@linkedin"  target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="LinkedIn"><i class="bi bi-linkedin text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(github))    { <a href="@github"    target="_blank" class="w-9 h-9 flex items-center justify-center hover:opacity-70 transition-opacity" style="background: var(--muted); color: var(--foreground);" title="GitHub"><i class="bi bi-github text-sm"></i></a> }
                </div>
            </div>
        </div>
    </div>
    @* Copyright *@
    <div class="border-t py-4 text-xs" style="border-color: var(--border); color: var(--muted-foreground);">
        <div class="container xl:max-w-6xl mx-auto px-4 flex items-center justify-between">
            <span>Copyright &copy; @DateTime.Now.Year @siteName. All rights reserved.</span>
            <a href="/" class="hover:opacity-60 transition-opacity">Home</a>
        </div>
    </div>
</footer>
