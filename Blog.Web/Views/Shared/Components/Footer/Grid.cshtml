@inject Blog.Core.Interfaces.ISettingRepository SettingsRepo
@{
    var userSettings = await SettingsRepo.GetSettingsAsync(ViewBag.OwnerId ?? Guid.Empty);
    var siteName = userSettings.SiteName;
    var siteDescription = userSettings.SiteDescription;
    string twitter   = userSettings.SocialTwitter;
    string facebook  = userSettings.SocialFacebook;
    string instagram = userSettings.SocialInstagram;
    string youtube   = userSettings.SocialYoutube;
    string linkedin  = userSettings.SocialLinkedin;
    string github    = userSettings.SocialGithub;
}

@* GRID footer — symmetric 2-col layout, primary left accent on brand, bordered icon grid *@
<footer style="background: var(--card); border-top: 1px solid var(--border);">
    <div class="container xl:max-w-6xl mx-auto px-4 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            @* Left: Brand + description *@
            <div class="flex flex-col gap-4">
                <a href="/" class="flex items-center gap-3 hover:opacity-70 transition-opacity">
                    <div class="w-2 h-8" style="background: var(--primary);"></div>
                    <span class="text-xl font-bold tracking-tight" style="color: var(--foreground);">@siteName</span>
                </a>
                <p class="text-sm leading-relaxed" style="color: var(--muted-foreground);">@siteDescription</p>
            </div>
            @* Right: Social icons grid *@
            <div class="flex flex-col gap-4">
                <span class="text-[10px] uppercase tracking-[0.2em] font-semibold" style="color: var(--muted-foreground);">Stay Connected</span>
                <div class="flex items-center gap-2 flex-wrap">
                    <a href="/feed" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity"
                       style="border-color: var(--primary); color: var(--primary); background: transparent;" title="RSS Feed">
                        <i class="bi bi-rss-fill text-sm"></i>
                    </a>
                    @if (!string.IsNullOrEmpty(twitter))   { <a href="@twitter"   target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="X / Twitter"><i class="bi bi-twitter-x text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(facebook))  { <a href="@facebook"  target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="Facebook"><i class="bi bi-facebook text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(instagram)) { <a href="@instagram" target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="Instagram"><i class="bi bi-instagram text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(youtube))   { <a href="@youtube"   target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="YouTube"><i class="bi bi-youtube text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(linkedin))  { <a href="@linkedin"  target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="LinkedIn"><i class="bi bi-linkedin text-sm"></i></a> }
                    @if (!string.IsNullOrEmpty(github))    { <a href="@github"    target="_blank" class="w-9 h-9 flex items-center justify-center border hover:opacity-60 transition-opacity" style="border-color: var(--border); color: var(--muted-foreground);" title="GitHub"><i class="bi bi-github text-sm"></i></a> }
                </div>
            </div>
        </div>
    </div>
    @* Copyright *@
    <div class="border-t py-4 text-xs" style="border-color: var(--border); color: var(--muted-foreground);">
        <div class="container xl:max-w-6xl mx-auto px-4 flex items-center justify-between">
            <span>Copyright &copy; @DateTime.Now.Year @siteName. All rights reserved.</span>
            <a href="/" class="hover:opacity-60 transition-opacity">Home</a>
        </div>
    </div>
</footer>
