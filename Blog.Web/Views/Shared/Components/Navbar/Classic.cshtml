@model Blog.Web.Models.NavbarViewModel
@{
    var sortedPages = Model.Pages.OrderBy(p => p.SortOrder).ToList();
    var logoUrl = !string.IsNullOrEmpty(Model.SiteLogoUrl)
        ? Model.SiteLogoUrl
        : $"https://placehold.co/400x120/171717/FFFFFF?text={Uri.EscapeDataString(Model.SiteName.ToUpper())}";
}

@* CLASSIC — Old newspaper left-aligned masthead: thick left accent · full-width top bar · stacked right icons *@
<header x-data="{ searchOpen: false, mobileOpen: false }"
        class="w-full sticky top-0 z-50 border-b-2"
        style="background: var(--background); border-color: var(--foreground);">

    <div class="container xl:max-w-6xl mx-auto px-4">
        <div class="flex items-stretch" style="min-height: 5rem;">

            @* Left accent column + site name *@
            <a href="/" class="flex items-center gap-4 flex-1 group py-4">
                <div class="w-1 self-stretch" style="background: var(--primary);"></div>
                <div class="flex flex-col justify-center">
                    <span class="text-3xl md:text-4xl font-black leading-none hover:opacity-80 transition-opacity"
                          style="font-family: var(--font-sans); color: var(--foreground);">@Model.SiteName.ToUpper()</span>
                    @if (!string.IsNullOrEmpty(Model.Tagline))
                    {
                        <span class="text-[10px] uppercase tracking-[0.2em] mt-1 font-medium" style="color: var(--muted-foreground);">@Model.Tagline</span>
                    }
                </div>
            </a>

            @* Center: logo *@
            <a href="/" class="hidden md:flex items-center px-6 border-l border-r" style="border-color: var(--border);">
                <img src="@logoUrl" alt="@Model.SiteName" class="h-12 w-auto object-contain" />
            </a>

            @* Right: stacked icon cluster *@
            <div class="flex items-center gap-1 pl-4">
                @* Pages *@
                <div class="relative" x-data="{ pagesOpen: false }">
                    <button @@click="pagesOpen = !pagesOpen" @@click.outside="pagesOpen = false"
                            class="w-10 h-10 flex items-center justify-center border hover:opacity-70 transition-opacity"
                            style="border-color: var(--border);" title="Pages">
                        <i class="bi bi-journals text-base"></i>
                    </button>
                    <div x-show="pagesOpen"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 -translate-y-1"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0"
                         style="display:none; background: var(--background); border-color: var(--border);"
                         class="absolute right-0 top-full mt-1 min-w-52 border-2 z-50" style="border-color: var(--foreground);">
                        <div class="px-4 py-2 text-[9px] uppercase tracking-[0.3em] font-bold border-b" style="border-color: var(--border); color: var(--muted-foreground); background: var(--muted);">Navigate</div>
                        <a href="/" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold hover:opacity-60 border-b" style="border-color: var(--border);">
                            <i class="bi bi-house" style="color: var(--primary);"></i> Home
                        </a>
                        @foreach (var p in sortedPages)
                        {
                            <a href="/@p.Slug" class="flex items-center gap-3 px-4 py-3 text-sm hover:opacity-60 border-b" style="border-color: var(--border); color: var(--foreground);">
                                <i class="bi bi-chevron-right text-xs" style="color: var(--muted-foreground);"></i> @p.Title
                            </a>
                        }
                    </div>
                </div>
                @* Search *@
                <button @@click="searchOpen = !searchOpen"
                        class="w-10 h-10 flex items-center justify-center border hover:opacity-70 transition-opacity"
                        style="border-color: var(--border);">
                    <i class="bi bi-search text-base"></i>
                </button>
                @* Dashboard *@
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/admin/dashboard"
                       class="hidden md:flex items-center px-4 h-10 text-xs font-bold uppercase tracking-widest hover:opacity-70 transition-opacity border"
                       style="border-color: var(--foreground); background: var(--foreground); color: var(--background);">
                        Admin
                    </a>
                }
                @* Mobile menu *@
                <button @@click="mobileOpen = !mobileOpen" class="md:hidden w-10 h-10 flex items-center justify-center border" style="border-color: var(--border);">
                    <i class="bi bi-list text-xl"></i>
                </button>
            </div>
        </div>
    </div>

    @* Mobile drawer *@
    <div x-show="mobileOpen" x-transition class="md:hidden border-t-2" style="border-color: var(--foreground); background: var(--background);">
        <div class="px-4 py-3 flex flex-col">
            <a href="/" class="py-3 text-sm font-semibold uppercase border-b hover:opacity-60" style="border-color: var(--border);">Home</a>
            @foreach (var p in sortedPages)
            {
                <a href="/@p.Slug" class="py-3 text-sm uppercase border-b hover:opacity-60" style="border-color: var(--border); color: var(--foreground);">@p.Title</a>
            }
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/admin/dashboard" class="mt-3 py-2 px-4 text-xs font-bold uppercase text-center" style="background: var(--foreground); color: var(--background);">Dashboard</a>
            }
        </div>
    </div>

    @* Search overlay *@
    <div x-show="searchOpen"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-[60] flex items-start justify-center pt-20" style="background: rgba(0,0,0,0.6);">
        <div @@click.away="searchOpen = false" class="w-full max-w-lg mx-4 border-2" style="background: var(--background); border-color: var(--foreground);">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-xs uppercase tracking-widest font-bold" style="color: var(--foreground);">Search the Archive</span>
                    <button @@click="searchOpen = false" class="text-xl hover:opacity-60">&times;</button>
                </div>
                <form action="/" method="get" class="flex border-b-2" style="border-color: var(--foreground);">
                    <input type="text" name="search" placeholder="What are you looking for?"
                           class="flex-1 h-11 px-0 bg-transparent text-sm outline-none"
                           style="color: var(--foreground);" />
                    <button type="submit" class="px-4 h-11 text-xs font-bold uppercase tracking-widest hover:opacity-70">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

</header>
