@model Blog.Web.Models.NavbarViewModel
@{
    var sortedPages = Model.Pages.OrderBy(p => p.SortOrder).ToList();
    var logoUrl = !string.IsNullOrEmpty(Model.SiteLogoUrl)
        ? Model.SiteLogoUrl
        : $"https://placehold.co/400x120/171717/FFFFFF?text={Uri.EscapeDataString(Model.SiteName.ToUpper())}";
}

@* MAGAZINE — Full-bleed bold header: inverted primary background, large site brand, icon cluster right *@
<header x-data="{ searchOpen: false, mobileOpen: false }" class="w-full">

    @* Main magazine band — inverted colours *@
    <div class="sticky top-0 z-50" style="background: var(--primary);">
        <div class="container xl:max-w-6xl mx-auto px-4">
            <div class="flex items-center justify-between" style="height: 4.5rem;">

                @* Site name — bold, inverted *@
                <a href="/" class="flex flex-col leading-none group">
                    <span class="text-2xl md:text-4xl font-black tracking-tight hover:opacity-80 transition-opacity"
                          style="color: var(--primary-foreground); font-family: var(--font-sans);">
                        @Model.SiteName.ToUpper()
                    </span>
                    @if (!string.IsNullOrEmpty(Model.Tagline))
                    {
                        <span class="text-[9px] uppercase tracking-[0.22em] mt-0.5 font-medium hidden md:block"
                              style="color: color-mix(in srgb, var(--primary-foreground) 70%, transparent);">@Model.Tagline</span>
                    }
                </a>

                @* Center: logo image *@
                <a href="/" class="absolute left-1/2 -translate-x-1/2 hidden md:flex">
                    <img src="@logoUrl" alt="@Model.SiteName" class="h-10 w-auto object-contain" />
                </a>

                @* Right icon cluster *@
                <div class="flex items-center gap-1">
                    @* Pages *@
                    <div class="relative" x-data="{ pagesOpen: false }">
                        <button @@click="pagesOpen = !pagesOpen" @@click.outside="pagesOpen = false"
                                class="w-10 h-10 rounded-md flex items-center justify-center hover:opacity-70 transition-opacity"
                                style="background: color-mix(in srgb, var(--primary-foreground) 15%, transparent); color: var(--primary-foreground);"
                                title="Pages">
                            <i class="bi bi-collection text-base"></i>
                        </button>
                        <div x-show="pagesOpen"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 scale-95"
                             x-transition:enter-end="opacity-100 scale-100"
                             x-transition:leave="transition ease-in duration-150"
                             x-transition:leave-start="opacity-100 scale-100"
                             x-transition:leave-end="opacity-0 scale-95"
                             style="display:none; background: var(--card); border-color: var(--border);"
                             class="absolute right-0 top-full mt-2 min-w-52 rounded-xl shadow-2xl border overflow-hidden z-50">
                            <div class="px-4 py-2.5 text-[9px] uppercase tracking-[0.3em] font-bold border-b" style="border-color: var(--border); color: var(--muted-foreground); background: var(--muted);">Jump To</div>
                            <a href="/" class="flex items-center gap-3 px-4 py-3.5 text-sm font-bold hover:opacity-70 border-b" style="border-color: var(--border); color: var(--foreground);">
                                <i class="bi bi-house-fill text-xs" style="color: var(--primary);"></i> Home
                            </a>
                            @foreach (var p in sortedPages)
                            {
                                <a href="/@p.Slug" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:opacity-70 border-b" style="border-color: var(--border); color: var(--foreground);">
                                    <i class="bi bi-arrow-right-short text-base" style="color: var(--primary);"></i> @p.Title
                                </a>
                            }
                        </div>
                    </div>
                    @* Search *@
                    <button @@click="searchOpen = !searchOpen"
                            class="w-10 h-10 rounded-md flex items-center justify-center hover:opacity-70 transition-opacity"
                            style="background: color-mix(in srgb, var(--primary-foreground) 15%, transparent); color: var(--primary-foreground);">
                        <i class="bi bi-search text-base"></i>
                    </button>
                    @* Dashboard *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/admin/dashboard"
                           class="hidden md:flex items-center px-4 h-9 text-xs font-bold uppercase tracking-wider rounded-md ml-1 hover:opacity-80 transition-opacity"
                           style="background: var(--primary-foreground); color: var(--primary);">
                            Dashboard
                        </a>
                    }
                    @* Mobile *@
                    <button @@click="mobileOpen = !mobileOpen"
                            class="md:hidden w-10 h-10 rounded-md flex items-center justify-center"
                            style="color: var(--primary-foreground);">
                        <i class="bi bi-list text-xl"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* Mobile menu *@
    <div x-show="mobileOpen" x-transition class="md:hidden" style="background: var(--primary);">
        <div class="px-4 py-3 flex flex-col gap-0.5 pb-4">
            <a href="/" class="py-2.5 text-sm font-semibold border-b hover:opacity-60" style="border-color: color-mix(in srgb, var(--primary-foreground) 20%, transparent); color: var(--primary-foreground);">Home</a>
            @foreach (var p in sortedPages)
            {
                <a href="/@p.Slug" class="py-2.5 text-sm border-b hover:opacity-60" style="border-color: color-mix(in srgb, var(--primary-foreground) 20%, transparent); color: var(--primary-foreground);">@p.Title</a>
            }
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/admin/dashboard" class="mt-3 py-2 px-4 text-xs font-bold uppercase text-center rounded" style="background: var(--primary-foreground); color: var(--primary);">Dashboard</a>
            }
        </div>
    </div>

    @* Search overlay *@
    <div x-show="searchOpen"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-[60] flex items-start justify-center pt-16" style="background: rgba(0,0,0,0.7);">
        <div @@click.away="searchOpen = false" class="w-full max-w-xl mx-4 rounded-2xl overflow-hidden shadow-2xl border" style="background: var(--background); border-color: var(--border);">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-bold" style="color: var(--foreground);">Search</h3>
                    <button @@click="searchOpen = false" class="text-2xl hover:opacity-60">&times;</button>
                </div>
                <form action="/" method="get" class="flex gap-2">
                    <input type="text" name="search" placeholder="Search posts…"
                           class="flex-1 h-11 px-4 rounded-lg border text-sm outline-none"
                           style="background: var(--muted); border-color: var(--border); color: var(--foreground);" />
                    <button type="submit" class="h-11 px-5 rounded-lg text-sm font-semibold" style="background: var(--primary); color: var(--primary-foreground);">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

</header>
