@model Blog.Web.Models.NavbarViewModel
@{
    var sortedPages = Model.Pages.OrderBy(p => p.SortOrder).ToList();
    var logoUrl = !string.IsNullOrEmpty(Model.SiteLogoUrl)
        ? Model.SiteLogoUrl
        : $"https://placehold.co/400x120/171717/FFFFFF?text={Uri.EscapeDataString(Model.SiteName.ToUpper())}";
}

@* GRID — Symmetric 3-column layout: [icons|name] · [logo] · [name|icons] *@
<header x-data="{ searchOpen: false, mobileOpen: false }"
        class="sticky top-0 z-50 w-full border-b"
        style="background: var(--background); border-color: var(--border);">

    <div class="container xl:max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-3 items-center" style="height: 4rem;">

            @* Column 1: site name (left) *@
            <div class="flex items-center justify-start">
                <a href="/" class="flex flex-col leading-none hover:opacity-70 transition-opacity">
                    <span class="text-lg md:text-xl font-bold tracking-tight" style="color: var(--foreground); font-family: var(--font-sans);">@Model.SiteName.ToUpper()</span>
                    @if (!string.IsNullOrEmpty(Model.Tagline))
                    {
                        <span class="text-[9px] uppercase tracking-[0.2em] font-medium hidden md:block" style="color: var(--muted-foreground);">@Model.Tagline</span>
                    }
                </a>
            </div>

            @* Column 2: logo (center) *@
            <div class="flex items-center justify-center">
                <a href="/" class="hover:opacity-80 transition-opacity">
                    <img src="@logoUrl" alt="@Model.SiteName" class="h-9 md:h-11 w-auto object-contain" />
                </a>
            </div>

            @* Column 3: icon cluster (right) *@
            <div class="flex items-center justify-end gap-1">

                @* Pages *@
                <div class="relative" x-data="{ pagesOpen: false }">
                    <button @@click="pagesOpen = !pagesOpen" @@click.outside="pagesOpen = false"
                            class="w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-70 transition-opacity border"
                            style="border-color: var(--border); color: var(--foreground); background: transparent;"
                            title="Pages">
                        <i class="bi bi-grid-3x3-gap text-sm"></i>
                    </button>
                    <div x-show="pagesOpen"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 scale-100"
                         x-transition:leave-end="opacity-0 scale-95"
                         style="display:none; background: var(--card); border-color: var(--border);"
                         class="absolute right-0 top-full mt-2 min-w-52 rounded-xl shadow-lg border overflow-hidden z-50">
                        <div class="px-4 py-2 text-[9px] uppercase tracking-[0.3em] font-semibold border-b" style="border-color: var(--border); color: var(--muted-foreground); background: var(--muted);">Pages</div>
                        <a href="/"
                           class="flex items-center gap-3 px-4 py-3 text-sm font-semibold hover:opacity-70 border-l-[3px]"
                           style="border-left-color: var(--primary); color: var(--foreground); border-bottom: 1px solid var(--border);">
                            <i class="bi bi-house-fill text-xs" style="color: var(--primary);"></i> Home
                        </a>
                        @foreach (var p in sortedPages)
                        {
                            <a href="/@p.Slug"
                               class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:opacity-70 border-l-[3px] border-l-transparent hover:border-l-primary"
                               style="color: var(--foreground); border-bottom: 1px solid var(--border);">
                                <i class="bi bi-file-text text-xs" style="color: var(--muted-foreground);"></i> @p.Title
                            </a>
                        }
                    </div>
                </div>

                @* Search *@
                <button @@click="searchOpen = !searchOpen"
                        class="w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-70 transition-opacity"
                        style="background: var(--muted); color: var(--muted-foreground);">
                    <i class="bi bi-search text-sm"></i>
                </button>

                @* Dashboard *@
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/admin/dashboard"
                       class="hidden md:flex items-center px-4 h-9 rounded-lg text-xs font-bold uppercase tracking-wider hover:opacity-80 transition-opacity"
                       style="background: var(--primary); color: var(--primary-foreground);">
                        Dashboard
                    </a>
                }

                @* Mobile *@
                <button @@click="mobileOpen = !mobileOpen"
                        class="md:hidden w-9 h-9 rounded-lg flex items-center justify-center border"
                        style="border-color: var(--border); color: var(--foreground);">
                    <i class="bi bi-list text-lg"></i>
                </button>
            </div>
        </div>
    </div>

    @* Mobile menu *@
    <div x-show="mobileOpen" x-transition class="md:hidden border-t" style="background: var(--background); border-color: var(--border);">
        <div class="px-4 py-3 flex flex-col gap-1">
            <a href="/" class="px-3 py-2.5 rounded-lg text-sm font-medium hover:opacity-70" style="background: var(--muted); color: var(--foreground);">Home</a>
            @foreach (var p in sortedPages)
            {
                <a href="/@p.Slug" class="px-3 py-2.5 rounded-lg text-sm hover:opacity-70" style="background: var(--muted); color: var(--foreground);">@p.Title</a>
            }
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a href="/admin/dashboard" class="mt-1 px-3 py-2.5 rounded-lg text-sm font-semibold text-center hover:opacity-80" style="background: var(--primary); color: var(--primary-foreground);">Dashboard</a>
            }
        </div>
    </div>

    @* Search modal *@
    <div x-show="searchOpen"
         x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-[60] flex items-start justify-center pt-20" style="background: rgba(0,0,0,0.55);">
        <div @@click.away="searchOpen = false"
             class="w-full max-w-lg mx-4 rounded-xl shadow-2xl border overflow-hidden"
             style="background: var(--card); border-color: var(--border);">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-base font-bold" style="color: var(--foreground);">Search Posts</h3>
                    <button @@click="searchOpen = false" class="text-2xl leading-none hover:opacity-60">&times;</button>
                </div>
                <form action="/" method="get" class="flex gap-2">
                    <input type="text" name="search" placeholder="Search posts…"
                           class="flex-1 h-11 px-4 rounded-lg border text-sm outline-none"
                           style="background: var(--background); border-color: var(--border); color: var(--foreground);" />
                    <button type="submit" class="h-11 px-4 rounded-lg text-sm font-semibold" style="background: var(--primary); color: var(--primary-foreground);">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

</header>
