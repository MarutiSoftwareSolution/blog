@model Blog.Web.Models.NavbarViewModel
@{
    var sortedPages = Model.Pages.OrderBy(p => p.SortOrder).ToList();
}

<header x-data="{ searchOpen: false }" class="sticky top-0 z-50 w-full relative" style="background: var(--background);">

    @* Top thick accent line *@
    <div class="h-[2px] w-full" style="background: var(--foreground);"></div>

    <div class="container xl:max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between" style="height: 4rem;">

            @* Left: Wordmark *@
            <a href="/" class="flex flex-col leading-none shrink-0">
                <span class="text-2xl font-black uppercase hover:opacity-70 transition-opacity"
                      style="font-family: var(--font-sans); color: var(--foreground); letter-spacing: -0.04em;">
                    @Model.SiteName
                </span>
                @if (!string.IsNullOrEmpty(Model.Tagline))
                {
                    <span class="text-[10px] uppercase font-medium mt-0.5"
                          style="color: var(--muted-foreground); letter-spacing: 0.18em;">@Model.Tagline</span>
                }
            </a>

            @* Center: Logo image only if explicitly set by user *@
            @if (!string.IsNullOrEmpty(Model.SiteLogoUrl))
            {
                <a href="/" class="absolute left-1/2 -translate-x-1/2">
                    <img src="@Model.SiteLogoUrl" alt="@Model.SiteName" class="h-8 w-auto object-contain" />
                </a>
            }

            @* Right: Icon cluster *@
            <div class="flex items-center gap-0.5">

                @* Pages dropdown *@
                <div class="relative" x-data="{ pagesOpen: false }">
                    <button @@click="pagesOpen = !pagesOpen"
                            @@click.outside="pagesOpen = false"
                            class="w-10 h-10 flex items-center justify-center hover:opacity-50 transition-opacity"
                            title="Pages">
                        <i class="bi bi-list text-xl"></i>
                    </button>
                    <div x-show="pagesOpen"
                         x-transition:enter="transition ease-out duration-150"
                         x-transition:enter-start="opacity-0 -translate-y-2"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-100"
                         x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0"
                         style="display:none; background: var(--background); border-top: 2px solid var(--foreground);"
                         class="absolute right-0 top-full min-w-52 z-50 shadow-xl">
                        <a href="/" class="flex items-center gap-3 px-5 py-3.5 text-sm font-bold uppercase hover:opacity-50 transition-opacity border-b"
                           style="border-color: var(--border); letter-spacing: 0.12em;">
                            <i class="bi bi-house text-xs"></i>
                            Home
                        </a>
                        @foreach (var navPage in sortedPages)
                        {
                            <a href="/@navPage.Slug"
                               class="flex items-center px-5 py-3 text-sm uppercase hover:opacity-50 transition-opacity border-b"
                               style="border-color: var(--border); color: var(--foreground); letter-spacing: 0.08em;">
                                @navPage.Title
                            </a>
                        }
                    </div>
                </div>

                @* Search *@
                <button @@click="searchOpen = !searchOpen"
                        class="w-10 h-10 flex items-center justify-center hover:opacity-50 transition-opacity">
                    <i class="bi bi-search text-base"></i>
                </button>

                @* Dashboard — inverted solid button shows only when logged in *@
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/admin/dashboard"
                       class="hidden md:flex items-center ml-3 px-4 h-8 text-xs font-bold uppercase hover:opacity-70 transition-opacity"
                       style="background: var(--foreground); color: var(--background); letter-spacing: 0.1em;">
                        Dashboard
                    </a>
                }
            </div>
        </div>
    </div>

    @* Bottom hairline *@
    <div class="h-px w-full" style="background: var(--border);"></div>

    @* Inline search flyout — drops below the header bar *@
    <div x-show="searchOpen"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         style="display:none; background: var(--background); border-bottom: 2px solid var(--foreground);"
         class="absolute top-full left-0 right-0 z-40 px-6 py-5">
        <div class="container xl:max-w-6xl mx-auto">
            <form action="/" method="get" class="flex items-center gap-4">
                <span class="text-xs uppercase font-bold shrink-0"
                      style="color: var(--muted-foreground); letter-spacing: 0.15em;">Search</span>
                <input type="text" name="search" placeholder="Type and press enter…"
                       class="flex-1 bg-transparent border-0 border-b text-sm outline-none py-1"
                       style="border-color: var(--foreground); color: var(--foreground);" />
                <button type="button" @@click="searchOpen = false"
                        class="text-xl hover:opacity-50 transition-opacity shrink-0">&times;</button>
            </form>
        </div>
    </div>

</header>
