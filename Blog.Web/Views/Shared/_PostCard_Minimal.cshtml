@model Blog.Core.Domain.Post

@* The Minimal layout renders posts inline in _Index_Minimal.cshtml.
   This card is used if _PostCard is called standalone in Minimal mode. *@
<article class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 py-8 border-b group"
         style="border-color: var(--border);">
    <div class="flex-1 min-w-0 flex flex-col gap-2">
        @if (Model.Categories != null && Model.Categories.Any())
        {
            <a href="/?category=@Model.Categories.First().Slug"
               class="text-[10px] font-black uppercase tracking-[0.2em] hover:opacity-60"
               style="color: var(--primary);">
                @Model.Categories.First().Name
            </a>
        }
        <h2 class="text-xl md:text-2xl font-bold leading-snug group-hover:opacity-60 transition-opacity">
            <a href="/@Model.Slug" style="color: var(--card-foreground);">@Model.Title</a>
        </h2>
        @if (!string.IsNullOrEmpty(Model.MetaDescription))
        {
            <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--muted-foreground);">@Model.MetaDescription</p>
        }
    </div>
    <div class="flex-shrink-0 text-right flex flex-col items-end gap-1">
        <time class="text-xs font-mono font-semibold uppercase tracking-wider" style="color: var(--muted-foreground);">
            @Model.PublishedAt?.ToString("MMM dd")
        </time>
        <time class="text-2xl font-black leading-none" style="color: var(--border);">
            @Model.PublishedAt?.ToString("yyyy")
        </time>
        <a href="/@Model.Slug" class="text-xs mt-2 font-bold uppercase tracking-widest underline underline-offset-2 hover:opacity-50"
           style="color: var(--primary);">Read →</a>
    </div>
</article>
