<div x-data="mediaSelector()" 
     x-show="isOpen" 
     @@keydown.escape.window="closeModal()"
     class="fixed inset-0 z-[100] flex items-center justify-center hidden"
     :class="{ 'hidden': !isOpen }">
    
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" 
         @@click="closeModal()"
         x-show="isOpen"
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"></div>

    <!-- Modal Content -->
    <div class="bg-card w-full max-w-4xl max-h-[90vh] rounded-xl shadow-2xl border border-border flex flex-col relative z-10 transform scale-100 overflow-hidden"
         x-show="isOpen"
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
         x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-border flex justify-between items-center bg-muted/30">
            <h2 class="text-xl font-semibold text-foreground">Select Media</h2>
            <div class="flex items-center gap-3">
                <label class="cursor-pointer px-3 py-1.5 bg-primary text-primary-foreground hover:bg-primary/90 text-sm font-medium rounded-md shadow-sm transition-colors" :class="{'opacity-50 pointer-events-none': uploading}">
                    <span x-show="!uploading">Upload New</span>
                    <span x-show="uploading">Uploading...</span>
                    <input type="file" class="hidden" accept="image/*" @@change="handleUpload" :disabled="uploading" />
                </label>
                <button @@click="closeModal()" class="text-muted-foreground hover:text-foreground transition-colors p-1 rounded-md hover:bg-muted">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
        </div>

        <!-- Body: Grid -->
        <div class="flex-1 overflow-y-auto p-6 bg-background/50">
            <template x-if="loading">
                <div class="flex justify-center items-center h-48">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                </div>
            </template>
            
            <template x-if="!loading && items.length === 0">
                 <div class="text-center py-12 text-muted-foreground">
                    <svg class="mx-auto h-12 w-12 text-muted-foreground/50 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>No images found in your library.</p>
                </div>
            </template>

            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-4">
                <template x-for="item in items" :key="item.id">
                    <div @@click="selectItem(item)" 
                         class="group relative aspect-square rounded-lg overflow-hidden border-2 cursor-pointer transition-all"
                         :class="selectedItem?.id === item.id ? 'border-primary ring-2 ring-primary/20 scale-95' : 'border-transparent hover:border-border'">
                        
                        <img :src="item.url" :alt="item.originalFileName" class="w-full h-full object-cover">
                        
                        <div class="absolute inset-0 bg-primary/20 opacity-0 transition-opacity flex items-center justify-center text-primary-foreground"
                             :class="{ 'opacity-100': selectedItem?.id === item.id }">
                             <svg x-show="selectedItem?.id === item.id" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-md"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        </div>
                    </div>
                </template>
            </div>
            
            <!-- Pagination Controls (Simple Next/Prev) -->
             <div class="mt-6 flex justify-center gap-2" x-show="total > 50">
                <button @@click="loadPage(page - 1)" :disabled="page <= 1" class="px-3 py-1 text-sm border border-input rounded disabled:opacity-50">Prev</button>
                <span class="px-3 py-1 text-sm">Page <span x-text="page"></span></span>
                <button @@click="loadPage(page + 1)" :disabled="items.length < 50" class="px-3 py-1 text-sm border border-input rounded disabled:opacity-50">Next</button>
            </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-border bg-muted/30 flex justify-between items-center">
            <div class="text-sm text-muted-foreground truncate max-w-[50%]">
                <span x-show="selectedItem" x-text="'Selected: ' + selectedItem?.originalFileName"></span>
            </div>
            <div class="flex gap-3">
                <button @@click="closeModal()" class="px-4 py-2 border border-input hover:bg-accent text-sm font-medium rounded-md transition-colors">Cancel</button>
                <button @@click="confirmSelection()" :disabled="!selectedItem" class="px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90 text-sm font-medium rounded-md shadow-sm transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                    Insert Image
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Make it globally available so any button can trigger it via a CustomEvent
    document.addEventListener('alpine:init', () => {
        Alpine.data('mediaSelector', () => ({
            isOpen: false,
            loading: false,
            uploading: false,
            items: [],
            total: 0,
            page: 1,
            selectedItem: null,
            targetInputId: null, // the ID of the hidden input to update for URL
            targetIdInput: null, // the ID of the hidden input to update for ID
            previewImgId: null,  // the ID of the img tag to update
            folder: 'images',

            init() {
                // Listen for custom event to open the modal
                window.addEventListener('open-media-selector', (e) => {
                    this.targetInputId = e.detail.targetInput;
                    this.targetIdInput = e.detail.targetIdInput;
                    this.previewImgId = e.detail.previewImg;
                    this.folder = e.detail.folder || 'images';
                    this.openModal();
                });
            },

            async openModal() {
                this.isOpen = true;
                this.selectedItem = null;
                if (this.items.length === 0) {
                    await this.loadPage(1);
                }
            },

            closeModal() {
                this.isOpen = false;
            },

            async loadPage(p) {
                this.loading = true;
                this.page = p;
                try {
                    const res = await fetch(`/admin/media/api?page=${p}`);
                    if (res.ok) {
                        const data = await res.json();
                        // Filter out non-images for the featured image selector
                        this.items = data.items.filter(i => {
                            const cType = i.contentType || "";
                            const name = (i.fileName || "").toLowerCase();
                            return cType.startsWith('image/') || name.endsWith('.jpg') || name.endsWith('.png') || name.endsWith('.webp') || name.endsWith('.gif') || name.endsWith('.jpeg');
                        });
                        this.total = data.total;
                    }
                } catch (e) {
                    console.error("Failed to load media", e);
                } finally {
                    this.loading = false;
                }
            },

            async handleUpload(event) {
                const file = event.target.files[0];
                if (!file) return;

                this.uploading = true;
                const formData = new FormData();
                formData.append('file', file);
                formData.append('folder', this.folder);
                
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    formData.append('__RequestVerificationToken', token);
                }

                try {
                    const res = await fetch('/admin/media/upload', {
                        method: 'POST',
                        body: formData
                    });

                    if (res.ok) {
                        const data = await res.json();
                        // Add the new item to the top of the list and select it
                        const newItem = {
                            id: data.id,
                            url: data.url,
                            fileName: data.fileName,
                            originalFileName: file.name,
                            contentType: file.type
                        };
                        this.items.unshift(newItem);
                        this.selectItem(newItem);
                    } else {
                        console.error("Upload failed", res.status);
                        alert("Failed to upload image.");
                    }
                } catch (e) {
                    console.error("Upload error", e);
                } finally {
                    this.uploading = false;
                    event.target.value = ''; // Reset file input
                }
            },

            selectItem(item) {
                this.selectedItem = item;
            },

            confirmSelection() {
                if (this.selectedItem) {
                    // Update hidden input
                    const input = document.getElementById(this.targetInputId);
                    if (input) {
                        input.value = this.selectedItem.url;
                        // Dispatch input event for any listeners (like Alpine)
                        input.dispatchEvent(new Event('input', { bubbles: true }));
                    }

                    if (this.targetIdInput) {
                        const idInput = document.getElementById(this.targetIdInput);
                        if (idInput) {
                            idInput.value = this.selectedItem.id;
                        }
                    }

                    // Update preview image
                    const img = document.getElementById(this.previewImgId);
                    if (img) {
                        img.src = this.selectedItem.url;
                        img.classList.remove('hidden');
                    }
                    
                    // Dispatch Custom Event for specific cases
                    window.dispatchEvent(new CustomEvent('media-selected', {
                        detail: { url: this.selectedItem.url, id: this.selectedItem.id }
                    }));

                    this.closeModal();
                }
            }
        }));
    });
</script>
