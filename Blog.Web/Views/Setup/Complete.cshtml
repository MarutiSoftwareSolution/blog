@{
    Layout = "_SetupLayout";
    ViewData["Title"] = "Setup Complete!";
}

<div class="setup-container">
    <div class="setup-card setup-complete">
        <div class="setup-logo">
            <svg width="72" height="72" viewBox="0 0 72 72" fill="none"><circle cx="36" cy="36" r="36" fill="#22c55e"/><path d="M20 36l10 10 22-22" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h1 class="setup-title">Your blog is live! 🎉</h1>
        <p class="setup-subtitle">BLGFRNT has been successfully installed. Head to your admin panel to start writing.</p>
        <a href="/admin/dashboard" class="btn btn-primary btn-lg">Go to Admin Panel →</a>
        <a href="/" class="btn btn-ghost">View Your Blog</a>
    </div>
</div>
